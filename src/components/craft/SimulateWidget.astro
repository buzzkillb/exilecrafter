---
// SimulateWidget.astro — Monte Carlo craft simulation for guide pages
// Runs client-side, loads real poe2db data from public/data/
// Shows success rate, items destroyed, and materials breakdown
---
<div class="simulate-widget parchment p-6 mb-6" id="simulate-widget">
  <div class="flex items-center justify-between mb-3">
    <h3 class="!m-0 text-lg font-display">Monte Carlo Simulation</h3>
    <button id="sim-run-btn" class="btn btn-danger text-sm px-4 py-1.5">
      ▶ Run Simulation
    </button>
  </div>
  <p class="text-xs text-dim mb-3">
    Runs <span id="sim-trials-display">200</span> trials using real poe2db mod weights.
    Shows success rate, items destroyed, and material costs.
  </p>
  <div class="flex gap-3 mb-3">
    <label class="text-xs text-dim">Trials:
      <select id="sim-trials" class="bg-bg border border-border rounded px-2 py-1 text-xs ml-1">
        <option value="50">50 (fast)</option>
        <option value="200" selected>200</option>
        <option value="500">500</option>
        <option value="1000">1000 (accurate)</option>
      </select>
    </label>
  </div>
  <div id="sim-results" class="hidden">
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-3">
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Success Rate</div>
        <div class="text-xl font-bold text-gold" id="sim-success">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Avg Cost</div>
        <div class="text-xl font-bold text-gold" id="sim-avg">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Median Cost</div>
        <div class="text-xl font-bold text-gold" id="sim-median">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">P10 – P90</div>
        <div class="text-sm font-bold text-gold" id="sim-range">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Items Destroyed</div>
        <div class="text-xl font-bold text-corrupted" id="sim-destroyed">-</div>
      </div>
    </div>
    <div class="parchment p-3 mb-3" id="sim-materials" style="display:none">
      <div class="text-xs text-dim mb-2">Avg Materials Per Success</div>
      <div class="grid grid-cols-3 sm:grid-cols-4 gap-x-4 gap-y-1 text-xs font-mono" id="sim-mats-grid"></div>
    </div>
    <div id="sim-log" class="text-xs text-dim font-mono max-h-32 overflow-y-auto"></div>
  </div>
</div>

<script>
  const runBtn = document.getElementById('sim-run-btn') as HTMLButtonElement;
  const trialsSelect = document.getElementById('sim-trials') as HTMLSelectElement;
  const trialsDisplay = document.getElementById('sim-trials-display')!;
  const resultsDiv = document.getElementById('sim-results')!;
  const successEl = document.getElementById('sim-success')!;
  const avgEl = document.getElementById('sim-avg')!;
  const medianEl = document.getElementById('sim-median')!;
  const rangeEl = document.getElementById('sim-range')!;
  const destroyedEl = document.getElementById('sim-destroyed')!;
  const materialsDiv = document.getElementById('sim-materials')!;
  const matsGrid = document.getElementById('sim-mats-grid')!;
  const logEl = document.getElementById('sim-log')!;

  trialsSelect.addEventListener('change', () => { trialsDisplay.textContent = trialsSelect.value; });

  let running = false;
  let dataLoaded = false;
  let mods: any[] = [];
  let bases: any[] = [];

  async function loadData() {
    if (dataLoaded) return;
    const [modsRes, basesRes] = await Promise.all([fetch('/data/mods.json'), fetch('/data/bases.json')]);
    mods = await modsRes.json();
    bases = await basesRes.json();
    dataLoaded = true;
  }

  function buildPool(allMods: any[], type: string, slot: string, ilvl: number) {
    return allMods.filter((m: any) => {
      if (m.type !== type && m.type !== 'any') return false;
      if (m.domain?.length > 0 && !m.domain.includes(slot)) return false;
      if (m.level > ilvl) return false;
      return true;
    }).map((m: any) => ({
      id: m.id, name: m.name, tier: m.tier, type: m.type,
      weight: m.weight > 0 ? m.weight : Math.pow(2, 10 - m.tier) * 10,
    }));
  }

  function pickFromPool(pool: any[]) {
    const totalW = pool.reduce((s: number, e: any) => s + e.weight, 0);
    if (totalW <= 0) return pool[0] || null;
    let roll = Math.random() * totalW;
    for (const entry of pool) {
      roll -= entry.weight;
      if (roll <= 0) return entry;
    }
    return pool[pool.length - 1];
  }

  const BOOT_PRICES: Record<string, number> = {
    base_ilvl82: 1.0, orb_of_transmutation: 0.001, orb_of_augmentation: 0.002,
    regal_orb: 0.02, exalted_orb: 0.15, greater_exalted_orb: 0.5,
    perfect_exalted_orb: 3.0, chaos_orb: 0.01, orb_of_annulment: 0.15,
    fracturing_orb: 1.5, divine_orb: 1.0,
    omen_of_greater_exaltation: 2.0, omen_of_dextral_exaltation: 0.5,
    omen_of_sinistral_exaltation: 0.5, omen_of_crystallisation: 1.0,
    preserved_rib: 1.5,
  };

  function simBootCraft(): { cost: number; destroyed: boolean; materials: Record<string, number> } {
    const mats: Record<string, number> = {};
    const add = (k: string, v = 1) => { mats[k] = (mats[k] || 0) + v; };
    let cost = 0;

    const base = bases.find((b: any) => b.name === 'Sekhema Sandals');
    if (!base) return { cost: 0, destroyed: false, materials: mats };

    cost += BOOT_PRICES.base_ilvl82; add('base');

    // Step 1: Transmute + Augment until T1 movement speed
    let hit = false;
    for (let attempt = 0; attempt < 50; attempt++) {
      cost += BOOT_PRICES.orb_of_transmutation + BOOT_PRICES.orb_of_augmentation;
      add('transmute'); add('augment');
      const prefixPool = buildPool(mods, 'prefix', base.slot, 82);
      const p = pickFromPool(prefixPool);
      if (p && p.name.toLowerCase().includes('movement speed') && p.tier === 1) { hit = true; break; }
      if (attempt === 49) return { cost, destroyed: true, materials: mats };
    }

    // Step 2: Fracture MS
    cost += BOOT_PRICES.fracturing_orb; add('fracturing');

    // Step 3: Regal + Chaos until T1 resistance
    hit = false;
    for (let attempt = 0; attempt < 50; attempt++) {
      cost += BOOT_PRICES.regal_orb; add('regal');
      if (attempt > 0) { cost += BOOT_PRICES.chaos_orb + BOOT_PRICES.orb_of_annulment; add('chaos'); add('annul'); }
      const suffixPool = buildPool(mods, 'suffix', base.slot, 82);
      const s = pickFromPool(suffixPool);
      if (s && s.name.toLowerCase().includes('resistance') && s.tier === 1) { hit = true; break; }
    }
    if (!hit) return { cost, destroyed: true, materials: mats };

    // Step 4-6: Dextral + Greater + 2x Perfect Exalt
    cost += BOOT_PRICES.omen_of_dextral_exaltation + BOOT_PRICES.omen_of_greater_exaltation;
    cost += BOOT_PRICES.perfect_exalted_orb * 2;
    add('omen_dextral'); add('omen_greater'); add('perfect_exalt', 2);

    // Step 7: Preserved Rib
    cost += BOOT_PRICES.preserved_rib; add('preserved_rib');

    // Step 8: Perfect Exalt for last prefix
    cost += BOOT_PRICES.perfect_exalted_orb; add('perfect_exalt');

    return { cost, destroyed: false, materials: mats };
  }

  const JEWEL_PRICES: Record<string, number> = {
    diamond_base: 0.1, orb_of_transmutation: 0.001, orb_of_augmentation: 0.002,
    regal_orb: 0.02, exalted_orb: 0.15, potent_liquid_contempt: 0.5,
    potent_liquid_ferocity: 0.5, preserved_cranium: 1.0,
    chaos_orb: 0.01, orb_of_annulment: 0.15, fracturing_orb: 1.5,
  };

  function simJewelCraft(): { cost: number; destroyed: boolean; materials: Record<string, number> } {
    const mats: Record<string, number> = {};
    const add = (k: string, v = 1) => { mats[k] = (mats[k] || 0) + v; };
    let cost = 0;
    let prefixCount = 0;
    let suffixCount = 0;
    // Diamond base: 3 prefix + 3 suffix natural cap
    const MAX_P = 3, MAX_S = 3;
    let bonusPrefixSlots = 0, bonusSuffixSlots = 0;

    const base = bases.find((b: any) => b.name === 'Diamond');
    if (!base) {
      const jewelBase = bases.find((b: any) => b.slot === 'jewel' && (b.level || 0) <= 80);
      if (!jewelBase) return { cost: 0, destroyed: false, materials: mats };
    }
    const ilvl = 82;

    cost += JEWEL_PRICES.diamond_base; add('base');

    // Step 1: Transmute → 1 random prefix
    cost += JEWEL_PRICES.orb_of_transmutation; add('transmute');
    const pfxPool = buildPool(mods, 'prefix', 'jewel', ilvl);
    const sfxPool = buildPool(mods, 'suffix', 'jewel', ilvl);
    const p1 = pickFromPool(pfxPool);
    if (!p1) return { cost, destroyed: true, materials: mats };
    prefixCount = 1;

    // Step 2: Augment → fills the MISSING type (suffix, since we have prefix)
    cost += JEWEL_PRICES.orb_of_augmentation; add('augment');
    const s1 = pickFromPool(sfxPool);
    if (!s1) return { cost, destroyed: true, materials: mats };
    suffixCount = 1;

    // Step 3: Regal → Rare (random type, 50/50)
    cost += JEWEL_PRICES.regal_orb; add('regal');
    if (Math.random() < 0.5) {
      const p2 = pickFromPool(pfxPool); if (!p2) return { cost, destroyed: true, materials: mats };
      prefixCount++;
    } else {
      const s2 = pickFromPool(sfxPool); if (!s2) return { cost, destroyed: true, materials: mats };
      suffixCount++;
    }

    // Step 4: Exalt to fill remaining slots to 3P+3S (at most 3 exalts needed)
    while (prefixCount < MAX_P || suffixCount < MAX_S) {
      cost += JEWEL_PRICES.exalted_orb; add('exalt');
      if (prefixCount < MAX_P && (suffixCount >= MAX_S || prefixCount <= suffixCount)) {
        const p = pickFromPool(pfxPool); if (p) prefixCount++;
      } else if (suffixCount < MAX_S) {
        const s = pickFromPool(sfxPool); if (s) suffixCount++;
      }
    }

    // Step 5: Potent Liquid Contempt
    // Removes a RANDOM affix (proportional to counts), then adds a random bonus slot (50/50 P/S)
    cost += JEWEL_PRICES.potent_liquid_contempt; add('liquid_contempt');

    const totalBefore = prefixCount + suffixCount;
    if (totalBefore > 0) {
      // Remove random mod: probability of prefix = prefixCount / totalBefore
      if (Math.random() < prefixCount / totalBefore) {
        prefixCount--;
      } else {
        suffixCount--;
      }
    }

    // Bonus slot: 50% prefix, 50% suffix
    const isPrefixBonus = Math.random() < 0.5;
    if (isPrefixBonus) bonusPrefixSlots++; else bonusSuffixSlots++;

    // Exalt into the new bonus slot
    cost += JEWEL_PRICES.exalted_orb; add('exalt');
    if (isPrefixBonus) {
      const p = pickFromPool(pfxPool); if (p) prefixCount++;
    } else {
      const s = pickFromPool(sfxPool); if (s) suffixCount++;
    }

    // Step 6: Potent Liquid Ferocity (optional, 80% of crafters use it)
    // Removes a random mod, adds (40-60)% increased Effect of Suffixes
    if (Math.random() < 0.8) {
      cost += JEWEL_PRICES.potent_liquid_ferocity; add('liquid_ferocity');
      const t = prefixCount + suffixCount;
      if (t > 0) {
        if (Math.random() < prefixCount / t) prefixCount--;
        else suffixCount--;
      }
      // Effect bonus doesn't change affix count, just adds cost + effect record
      add('ferocity_effect');
    }

    // Step 7: Preserved Cranium (optional, 60% use) — desecrates a prefix
    if (Math.random() < 0.6) {
      cost += JEWEL_PRICES.preserved_cranium; add('preserved_cranium');
      // Swap a random prefix with a fresh desecrated one from the pool
      if (prefixCount > 0) {
        const p = pickFromPool(pfxPool);
        if (p) { /* prefix replaced — same count */ }
      }
    }

    const totalAffixes = prefixCount + suffixCount;
    const destroyed = totalAffixes < 5;

    return { cost, destroyed, materials: mats };
  }

  runBtn.addEventListener('click', async () => {
    if (running) return;
    running = true;
    runBtn.textContent = '⏳ Running...';
    runBtn.disabled = true;
    resultsDiv.classList.remove('hidden');
    logEl.innerHTML = '';

    try {
      await loadData();
      const trials = parseInt(trialsSelect.value);
      const methodId = (window as any).__SIM_METHOD__ || 'boot';
      const simFn = methodId === 'jewel' ? simJewelCraft : simBootCraft;

      const costs: number[] = [];
      let successes = 0;
      let destroyed = 0;
      const totalMats: Record<string, number> = {};
      const batchSize = Math.min(trials, 50);
      const startTime = performance.now();

      for (let i = 0; i < trials; i++) {
        const result = simFn();
        if (result.destroyed) { destroyed++; }
        else if (result.cost > 0) { successes++; costs.push(result.cost); }
        for (const [k, v] of Object.entries(result.materials)) {
          totalMats[k] = (totalMats[k] || 0) + v;
        }
        if ((i + 1) % batchSize === 0) {
          const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
          logEl.innerHTML += `<div>Batch ${(i+1)/batchSize}: ${i+1}/${trials} trials (${elapsed}s)... ${successes} successes, ${destroyed} destroyed</div>`;
          await new Promise(r => setTimeout(r, 0));
        }
      }

      const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
      const rate = ((successes / trials) * 100).toFixed(1);
      const sorted = [...costs].sort((a, b) => a - b);
      const median = sorted.length > 0 ? sorted[Math.floor(sorted.length / 2)] : 0;
      const avg = sorted.length > 0 ? sorted.reduce((a, b) => a + b, 0) / sorted.length : 0;
      const p10 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.1)] : 0;
      const p90 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.9)] : 0;

      successEl.textContent = `${rate}%`;
      avgEl.textContent = `${avg.toFixed(1)} div`;
      medianEl.textContent = `${median.toFixed(1)} div`;
      rangeEl.textContent = `${p10.toFixed(1)} — ${p90.toFixed(1)} div`;
      destroyedEl.textContent = `${destroyed} / ${trials}`;

      // Material breakdown
      if (successes > 0 && Object.keys(totalMats).length > 0) {
        materialsDiv.style.display = 'block';
        const entries = Object.entries(totalMats)
          .sort((a, b) => b[1] - a[1])
          .map(([k, v]) => {
            const perSuccess = (v / successes).toFixed(1);
            const label = k.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            return `<span class="text-dim">${label}: <span class="text-fg">${perSuccess}</span></span>`;
          });
        matsGrid.innerHTML = entries.join('');
      }

      logEl.innerHTML += `<div class="text-gold mt-1">✅ ${trials} trials in ${elapsed}s — ${successes} successes (${rate}%), ${destroyed} destroyed</div>`;
    } catch (err: any) {
      logEl.innerHTML += `<div class="text-corrupted">Error: ${err.message || err}</div>`;
    } finally {
      running = false;
      runBtn.textContent = '▶ Run Simulation';
      runBtn.disabled = false;
    }
  });
</script>
