---
// SimulateWidget.astro — Monte Carlo craft simulation for guide pages
// Runs client-side, loads real poe2db data from public/data/
---
<div class="simulate-widget parchment p-6 mb-6" id="simulate-widget">
  <div class="flex items-center justify-between mb-3">
    <h3 class="!m-0 text-lg font-display">Monte Carlo Simulation</h3>
    <button id="sim-run-btn" class="btn btn-danger text-sm px-4 py-1.5">
      ▶ Run Simulation
    </button>
  </div>
  <p class="text-xs text-dim mb-3">
    Runs <span id="sim-trials-display">200</span> trials using real poe2db mod weights.
    Shows expected Divine Orb cost and success probability.
  </p>
  <div class="flex gap-3 mb-3">
    <label class="text-xs text-dim">Trials:
      <select id="sim-trials" class="bg-bg border border-border rounded px-2 py-1 text-xs ml-1">
        <option value="50">50 (fast)</option>
        <option value="200" selected>200</option>
        <option value="500">500</option>
        <option value="1000">1000 (accurate)</option>
      </select>
    </label>
  </div>
  <div id="sim-results" class="hidden">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Success Rate</div>
        <div class="text-xl font-bold text-gold" id="sim-success">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Avg Cost</div>
        <div class="text-xl font-bold text-gold" id="sim-avg">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">Median Cost</div>
        <div class="text-xl font-bold text-gold" id="sim-median">-</div>
      </div>
      <div class="parchment p-3 text-center">
        <div class="text-xs text-dim">P10 – P90</div>
        <div class="text-sm font-bold text-gold" id="sim-range">-</div>
      </div>
    </div>
    <div id="sim-log" class="text-xs text-dim font-mono max-h-32 overflow-y-auto"></div>
  </div>
</div>

<script>
  const runBtn = document.getElementById('sim-run-btn') as HTMLButtonElement;
  const trialsSelect = document.getElementById('sim-trials') as HTMLSelectElement;
  const trialsDisplay = document.getElementById('sim-trials-display')!;
  const resultsDiv = document.getElementById('sim-results')!;
  const successEl = document.getElementById('sim-success')!;
  const avgEl = document.getElementById('sim-avg')!;
  const medianEl = document.getElementById('sim-median')!;
  const rangeEl = document.getElementById('sim-range')!;
  const logEl = document.getElementById('sim-log')!;

  trialsSelect.addEventListener('change', () => {
    trialsDisplay.textContent = trialsSelect.value;
  });

  let running = false;
  let dataLoaded = false;
  let mods: any[] = [];
  let bases: any[] = [];

  async function loadData() {
    if (dataLoaded) return;
    const [modsRes, basesRes] = await Promise.all([
      fetch('/data/mods.json'), fetch('/data/bases.json'),
    ]);
    mods = await modsRes.json();
    bases = await basesRes.json();
    dataLoaded = true;
  }

  function buildPool(mods: any[], type: string, slot: string, ilvl: number) {
    return mods.filter((m: any) => {
      if (m.type !== type && m.type !== 'any') return false;
      if (m.domain?.length > 0 && !m.domain.includes(slot)) return false;
      if (m.level > ilvl) return false;
      return true;
    }).map((m: any) => ({
      id: m.id, name: m.name, tier: m.tier, type: m.type,
      weight: (m.weight > 0) ? m.weight : Math.pow(2, 10 - m.tier) * 10,
    }));
  }

  function pickFromPool(pool: any[]) {
    const totalW = pool.reduce((s: number, e: any) => s + e.weight, 0);
    if (totalW <= 0) return pool[0] || null;
    let roll = Math.random() * totalW;
    for (const entry of pool) {
      roll -= entry.weight;
      if (roll <= 0) return entry;
    }
    return pool[pool.length - 1];
  }

  function simBootCraft(): { cost: number; log: string[]; success: boolean } {
    const log: string[] = [];
    let cost = 0;
    const PRICES: Record<string, number> = {
      base_ilvl82: 1.0, orb_of_transmutation: 0.001, orb_of_augmentation: 0.002,
      regal_orb: 0.02, orb_of_alchemy: 0.05, exalted_orb: 0.15,
      greater_exalted_orb: 0.5, perfect_exalted_orb: 3.0,
      chaos_orb: 0.01, orb_of_annulment: 0.15, fracturing_orb: 1.5,
      vaal_orb: 0.02, divine_orb: 1.0,
      omen_of_greater_exaltation: 2.0, omen_of_dextral_exaltation: 0.5,
      omen_of_sinistral_exaltation: 0.5, omen_of_crystallisation: 1.0,
      preserved_rib: 1.5, ancient_rib: 1.0, gnawed_rib: 0.5,
    };

    const base = bases.find((b: any) => b.name === 'Sekhema Sandals');
    if (!base) return { cost: 0, log: ['Base not found in data'], success: false };

    cost += PRICES.base_ilvl82;
    const item: any = { base, ilvl: 82, rarity: 'normal', affixes: [] };

    // Step 1: Transmute + Alt until T1 movement speed
    for (let attempt = 0; attempt < 50; attempt++) {
      cost += PRICES.orb_of_transmutation + PRICES.orb_of_augmentation;
      item.rarity = 'magic';
      const prefixPool = buildPool(mods, 'prefix', base.slot, 82);
      const p = pickFromPool(prefixPool);
      if (p && p.name.toLowerCase().includes('movement speed') && p.tier === 1) {
        log.push(`Hit T1 MS on attempt ${attempt + 1}`); break;
      }
      if (attempt === 49) return { cost, log: [...log, 'Failed to find T1 MS'], success: false };
    }

    // Step 2: Fracture the MS
    cost += PRICES.fracturing_orb;

    // Step 3: Regal + Chaos until T1 resist
    let hitRes = false;
    for (let attempt = 0; attempt < 50; attempt++) {
      cost += PRICES.regal_orb;
      if (attempt > 0) cost += PRICES.chaos_orb + PRICES.orb_of_annulment;
      const suffixPool = buildPool(mods, 'suffix', base.slot, 82);
      const s = pickFromPool(suffixPool);
      if (s && s.name.includes('resistance') && s.tier === 1) { hitRes = true; break; }
    }
    if (!hitRes) return { cost, log: [...log, 'Failed to find T1 resist'], success: false };
    log.push('T1 resist after chaos spam');

    // Step 4-6: Dextral + Greater + Perfect Exalt
    cost += PRICES.omen_of_dextral_exaltation + PRICES.omen_of_greater_exaltation
          + PRICES.perfect_exalted_orb * 2;
    log.push('Dextral + Greater + 2x Perfect Exalt');

    // Step 7: Preserved Rib
    cost += PRICES.preserved_rib;

    // Step 8: Perfect Exalt for last prefix
    cost += PRICES.perfect_exalted_orb;

    return { cost, log, success: true };
  }

  function simJewelCraft(): { cost: number; log: string[]; success: boolean } {
    const PRICES: Record<string, number> = {
      diamond_base: 0.1, orb_of_transmutation: 0.001, orb_of_augmentation: 0.002,
      regal_orb: 0.02, exalted_orb: 0.15, potent_liquid_contempt: 0.5,
      potent_liquid_ferocity: 0.5, preserved_cranium: 1.0,
    };
    let cost = PRICES.diamond_base;
    cost += PRICES.orb_of_transmutation + PRICES.orb_of_augmentation + PRICES.regal_orb;
    cost += PRICES.exalted_orb * 3;
    cost += PRICES.potent_liquid_contempt + PRICES.exalted_orb;
    cost += PRICES.potent_liquid_ferocity;
    cost += PRICES.preserved_cranium;
    return { cost, log: ['Jewel craft completed'], success: true };
  }

  runBtn.addEventListener('click', async () => {
    if (running) return;
    running = true;
    runBtn.textContent = '⏳ Running...';
    runBtn.disabled = true;
    resultsDiv.classList.remove('hidden');
    logEl.innerHTML = '';

    try {
      await loadData();
      const trials = parseInt(trialsSelect.value);
      const methodId = (window as any).__SIM_METHOD__ || 'boot';
      const simFn = methodId === 'jewel' ? simJewelCraft : simBootCraft;

      const costs: number[] = [];
      let successes = 0;
      const batchSize = Math.min(trials, 50);
      const startTime = performance.now();

      for (let i = 0; i < trials; i++) {
        const result = simFn();
        if (result.success) { successes++; costs.push(result.cost); }
        if ((i + 1) % batchSize === 0) {
          const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
          logEl.innerHTML += `<div>Batch ${(i+1)/batchSize}: ${i+1}/${trials} trials (${elapsed}s)... ${successes} successes so far</div>`;
          await new Promise(r => setTimeout(r, 0)); // yield to keep UI responsive
        }
      }

      const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
      const rate = ((successes / trials) * 100).toFixed(1);
      const sorted = [...costs].sort((a, b) => a - b);
      const median = sorted.length > 0 ? sorted[Math.floor(sorted.length / 2)] : 0;
      const avg = sorted.length > 0 ? sorted.reduce((a, b) => a + b, 0) / sorted.length : 0;
      const p10 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.1)] : 0;
      const p90 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.9)] : 0;

      successEl.textContent = `${rate}%`;
      avgEl.textContent = `${avg.toFixed(1)} div`;
      medianEl.textContent = `${median.toFixed(1)} div`;
      rangeEl.textContent = `${p10.toFixed(1)} — ${p90.toFixed(1)} div`;
      logEl.innerHTML += `<div class="text-gold mt-1">✅ ${trials} trials in ${elapsed}s — ${successes} successes (${rate}%)</div>`;
    } catch (err: any) {
      logEl.innerHTML += `<div class="text-corrupted">Error: ${err.message || err}</div>`;
    } finally {
      running = false;
      runBtn.textContent = '▶ Run Simulation';
      runBtn.disabled = false;
    }
  });
</script>
