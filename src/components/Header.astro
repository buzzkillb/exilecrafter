---
import { season } from '~/lib/data';
import { useT, type Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props as Props;
const t = useT(locale);

const path = Astro.url.pathname;
const links = [
  { href: '/', label: t('nav.home') },
  { href: '/bases', label: t('nav.bases') },
  { href: '/mods', label: t('nav.mods') },
  { href: '/currency', label: t('nav.currency') },
  { href: '/omens', label: t('nav.omens') },
  { href: '/simulator', label: t('nav.simulator') },
  { href: '/calculator', label: t('nav.calculator') },
  { href: '/guides', label: t('nav.guides') },
  { href: '/optimizer', label: 'Optimizer' },

];
---

<header class="site-header">
  <div class="container mx-auto max-w-7xl px-4 py-3 flex items-center gap-6 flex-wrap">
    <a href="/" class="brand">EXILECRAFTER</a>
    <nav class="flex items-center gap-1 ml-auto flex-wrap">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'px-3 py-1.5 text-sm rounded transition-colors',
            path === l.href || (l.href !== '/' && path.startsWith(l.href))
              ? 'text-gold-bright bg-bg-elev'
              : 'text-fg-dim hover:text-gold-bright hover:bg-bg-elev',
          ]}
        >
          {l.label}
        </a>
      ))}
      <div id="header-prices" class="ml-3 flex items-center gap-1.5 text-xs font-mono whitespace-nowrap">
        <span class="text-mute text-[10px]">loading…</span>
      </div>
    </nav>
  </div>
</header>

<script>
  // Live economy rates in the header — fetched from /api/prices (poe2scout).
  (async () => {
    const el = document.getElementById('header-prices');
    if (!el) return;
    try {
      const res = await fetch('/api/prices');
      if (!res.ok) { el.innerHTML = ''; return; }
      const raw = await res.json();
      const meta = raw._meta || {};
      const divineC = raw.divine_orb ?? meta.chaosPerDivine ?? 7.5;
      const exaltC = raw.exalted_orb ?? 0.018;
      const divineX = exaltC > 0 ? divineC / exaltC : 0;
      const t = meta.fetchedAt ? new Date(meta.fetchedAt).toLocaleTimeString() : '';
      el.innerHTML =
        '<span class="inline-flex items-center gap-1 text-xs font-mono">' +
          '<img src="/images/currency/divine_orb.webp" alt="" class="w-4 h-4" />' +
          '<span class="text-gold-bright font-semibold">' + divineC.toFixed(1) + 'c</span>' +
        '</span>' +
        '<span class="inline-flex items-center gap-1 text-xs font-mono ml-2">' +
          '<img src="/images/currency/exalted_orb.webp" alt="" class="w-4 h-4" />' +
          '<span class="text-dim font-semibold">' + divineX.toFixed(0) + 'x</span>' +
        '</span>' +
        '<span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block shrink-0 ml-2" title="Live from poe2scout · ' + t + '"></span>';
    } catch (_) { el.innerHTML = ''; }
  })();
</script>
