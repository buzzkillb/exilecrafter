---
export interface Props {}
---

<div class="flex gap-2">
  <button id="undo-btn" class="btn btn-danger text-xs flex-1" title="Undo last craft [Z]" aria-label="Undo last craft">
    ↶ Undo
  </button>
  <button id="copy-btn" class="btn btn-danger text-xs flex-1" title="Copy item to clipboard" aria-label="Copy item to clipboard">
    📋 Copy
  </button>
  <button id="paste-btn" class="btn btn-danger text-xs flex-1" title="Paste an item from in-game copy" aria-label="Paste an item">
    📋 Paste
  </button>
  <button id="seed-rare-btn" class="btn btn-danger text-xs flex-1" title="Jump straight to a 6-mod Rare (Alchemy + 2 Exalts)" aria-label="Seed a Rare item">
    ⚡ Seed Rare
  </button>
  <button id="reset-btn" class="btn btn-danger text-xs flex-1" title="Reset to a fresh Normal item" aria-label="Reset item">
    ↺ Reset
  </button>
</div>
