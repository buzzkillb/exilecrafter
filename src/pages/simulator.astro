---
import Base from '~/layouts/Base.astro';
import { bases } from '~/lib/data';
import { useT } from '~/lib/i18n';

const locale = (Astro.locals.locale as 'en' | 'pt') ?? 'en';
const t = useT(locale);

const baseOptions = bases.map((b) => ({
  id: b.id, name: b.name, slot: b.slot, level: b.level,
  affixSlots: b.affixSlots, imageUrl: b.imageUrl, variant: b.variant,
}));

// Crafting examples — curated base + description + suggested goal
const craftingExamples = [
  {
    id: bases.find((b) => b.name === 'Sapphire')?.id || '',
    name: 'Sapphire Jewel',
    tag: '💎 Expert',
    description: 'Craft a top-tier jewel using Essences, Liquid Emotions, Desecration & Fracturing.',
    goal: '5-mod jewel with 40-60% increased Effect of Suffixes',
    difficulty: 'expert',
  },
  {
    id: bases.find((b) => b.name === 'Ancestral Tiara')?.id || '',
    name: 'Ancestral Tiara',
    tag: '🎯 Endgame',
    description: 'High-end Energy Shield helmet. Roll life, resistances, and mana with real tier gates.',
    goal: '3P/3S ES helmet at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Flying Spear')?.id || '',
    name: 'Flying Spear',
    tag: '🗡️ Weapon',
    description: 'One-handed spear with physical damage, attack speed, and crit chance.',
    goal: '3P/3S DPS weapon at ilvl 78',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Gold Amulet')?.id || '',
    name: 'Gold Amulet',
    tag: '📿 Amulet',
    description: 'High-end jewellery base with increased Rarity of Items Found. Roll life, resists, spirit.',
    goal: '3P/2S magic-find amulet at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Gold Ring')?.id || '',
    name: 'Gold Ring',
    tag: '💍 Rings',
    description: 'Top-tier ring base with innate increased rarity. Roll resists, damage, attributes.',
    goal: '2P/2S MF ring at ilvl 80 for mapping',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Two-Stone Ring')?.id || '',
    name: 'Two-Stone Ring',
    tag: '💍 Rings',
    description: 'Versatile leveling ring with dual elemental resistances. Easy to craft.',
    goal: '2P/2S ring for early endgame',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Tasalian Greaves')?.id || '',
    name: 'Tasalian Greaves',
    tag: '👢 Boots',
    description: 'High-end evasion/ES boots. Roll movement speed, resistances, and attributes.',
    goal: '2P/2S endgame boots at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Waystone (Tier 16)')?.id || '',
    name: 'Waystone (Tier 16)',
    tag: '🗺️ Map',
    description: 'Endgame waystone. Mod quantity, rarity, pack size for maximum loot.',
    goal: 'Max-rolled T16 waystone for juiced mapping',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Warlord Cuirass')?.id || '',
    name: 'Warlord Cuirass',
    tag: '🛡️ Armour',
    description: 'High-level body armour. Roll life, resistances, and armour/ES hybrid mods.',
    goal: '3P/3S endgame chest at ilvl 80',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Solar Amulet')?.id || '',
    name: 'Solar Amulet',
    tag: '📿 Mid-Level',
    description: 'All-around amulet craft. Roll +spirit, resistances, and attributes.',
    goal: '2P/2S amulet at ilvl 30',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Broadhead Quiver')?.id || '',
    name: 'Broadhead Quiver',
    tag: '🏹 Quiver',
    description: 'Budget quiver craft. Roll increased damage, attack speed, and crit chance.',
    goal: '2P/2S damage quiver at ilvl 1',
    difficulty: 'beginner',
  },
  {
    id: bases.find((b) => b.name === 'Iron Ring')?.id || '',
    name: 'Iron Ring',
    tag: '⭕ Beginner',
    description: 'Simple ring to learn the basics. Alchemy, Essences, and Chaos spam.',
    goal: '2P/2S starter ring at ilvl 1',
    difficulty: 'beginner',
  },
].filter((ex) => ex.id);

// Static UI strings passed to the client-side simulator for runtime use.
const i18nStrings = JSON.stringify({
  undo: t('simulator.undo'),
  seedRare: t('simulator.seedRare'),
  reset: t('simulator.reset'),
  emptyTitle: t('simulator.empty.title'),
  emptySubtitle: t('simulator.empty.subtitle'),
  pickBase: t('calculator.flash.pickbase'),
  addOmens: t('simulator.addOmens'),
  addOmensLabel: t('simulator.addOmensLabel'),
  apply: t('simulator.apply'),
  activeOmens: t('simulator.activeOmens'),
  clearAll: t('simulator.activeOmens.clear'),
  activeOmensHint: t('simulator.activeOmens.hint'),
  reference: t('simulator.reference'),
  expandHint: t('simulator.reference.expand'),
  poolTitle: t('simulator.modpool'),
  poolEmpty: t('simulator.modpool.empty'),
  history: t('simulator.history'),
  noCurrency: t('simulator.empty.actions'),
  shortcutHint: t('simulator.shortcuts'),
  itemLevelLabel: t('simulator.itemlevel.label'),
  corrupted: t('simulator.corrupted'),
  emptyItem: t('simulator.empty.pool'),
  sectionPrefix: t('simulator.section.prefix'),
  sectionSuffix: t('simulator.section.suffix'),
  slotLabel: t('simulator.slot.label'),
  rarityLabel: t('simulator.rarity.label'),
});
---

<Base title={`${t('simulator.title')} - CraftClass`}>
  <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
    <h1 class="!m-0">Simulator</h1>
    <div class="flex items-center gap-2 min-w-0 flex-1 sm:flex-initial">
      <select id="base-picker" class="bg-bg border border-border-strong rounded px-3 py-1.5 text-sm focus:outline-none focus:border-gold min-w-0 flex-1 sm:flex-initial sm:w-72">
        <option value="">Choose a base…</option>
      </select>
      <label class="flex items-center gap-1 text-xs text-mute" title="Item level - gates which tiers can roll">
        ilvl
        <input id="ilvl-input" type="number" value="80" min="1" max="100" class="w-14 bg-bg border border-border-strong rounded px-2 py-1.5 text-sm focus:outline-none focus:border-gold" />
      </label>
    </div>
  </div>

  <div class="max-w-5xl mx-auto">
    <!-- Loading state -->
    <div id="loading-state" class="parchment p-6 text-center">
      <div class="text-3xl mb-2">⏳</div>
      <div class="font-display text-xl text-fg mb-1">Loading data…</div>
      <p class="text-sm text-dim">Fetching mods, currencies, and omens from the database.</p>
    </div>

    <!-- Empty state with quick picks -->
    <div id="empty-state" class="hidden parchment p-6 text-center">
      <div class="text-3xl mb-2">⚒️</div>
      <div class="font-display text-xl text-fg mb-1">Pick a base to start crafting</div>
      <p class="text-sm text-dim mb-4">Or try one of these popular starters:</p>
      <div class="mb-4">
        <button id="paste-empty-btn" class="btn text-sm px-4 py-2 border border-gold/40 text-gold hover:bg-gold/10 rounded-lg transition-all">
          📋 Paste an item from your clipboard
        </button>
      </div>
      <div id="quick-picks" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 justify-center">
        {craftingExamples.map((ex) => {
          const b = bases.find((x) => x.id === ex.id);
          const difficultyColors: Record<string, string> = {
            beginner: 'border-green-700/40 text-green-400',
            intermediate: 'border-blue-700/40 text-blue-400',
            advanced: 'border-purple-700/40 text-purple-400',
            expert: 'border-gold/40 text-gold',
          };
          const diffCls = difficultyColors[ex.difficulty] || 'border-border text-mute';
          return b ? (
            <button class="flex flex-col items-start gap-1 p-3 border rounded-lg text-left transition-all hover:border-gold hover:bg-bg-card/60 cursor-pointer w-full quick-pick-btn" data-base={b.id} data-name={b.name}>
              <div class="flex items-center gap-2 w-full">
                {b.imageUrl && <img src={b.imageUrl} alt="" class="w-7 h-7 shrink-0" />}
                <span class="font-semibold text-sm text-fg leading-tight">{ex.name}</span>
                <span class="ml-auto text-[10px] font-medium uppercase tracking-wide px-1.5 py-0.5 rounded border {diffCls}">{ex.tag}</span>
              </div>
              <p class="text-[11px] text-dim leading-relaxed">{ex.description}</p>
              <span class="text-[10px] text-mute italic">→ {ex.goal}</span>
            </button>
          ) : null;
        })}
      </div>
    </div>

    <div id="main-ui" class="hidden grid lg:grid-cols-[1fr_360px] gap-3">
      <!-- LEFT: Item + history -->
      <div class="space-y-3 min-w-0">
        <!-- Item display -->
        <div id="item-display" class="parchment p-3"></div>

        <!-- Active omens strip -->
        <div id="active-omens-strip" class="parchment p-2 hidden">
          <div class="flex items-center justify-between mb-1.5">
            <div class="text-xs uppercase tracking-wider text-gold font-semibold">Active Omens</div>
            <button id="clear-omens-btn" class="text-xs text-mute hover:text-gold-bright">Clear all</button>
          </div>
          <div id="active-omens-chips" class="flex flex-wrap gap-1.5"></div>
          <div class="text-xs text-mute mt-1">These alter your next currency action, then expire.</div>
        </div>

        <!-- Tips -->
        <div id="tips-panel" class="parchment p-3 text-sm"></div>

        <!-- Quick action bar -->
        <div class="flex gap-2">
          <button id="undo-btn" class="btn text-xs flex-1" title="Undo last craft [Z]" aria-label="Undo last craft">
            ↶ Undo
          </button>
          <button id="copy-btn" class="btn text-xs flex-1" title="Copy item to clipboard" aria-label="Copy item to clipboard">
            📋 Copy
          </button>
          <button id="paste-btn" class="btn text-xs flex-1" title="Paste an item from in-game copy" aria-label="Paste an item">
            📋 Paste
          </button>
          <button id="seed-rare-btn" class="btn text-xs flex-1" title="Jump straight to a 6-mod Rare (Alchemy + 2 Exalts)" aria-label="Seed a Rare item">
            ⚡ Seed Rare
          </button>
          <button id="reset-btn" class="btn text-xs flex-1" title="Reset to a fresh Normal item" aria-label="Reset item">
            ↺ Reset
          </button>
        </div>

        <!-- Reference & Log (always expanded, above activity log) -->
        <details class="parchment" open>
          <summary class="p-3 cursor-pointer text-sm text-fg-dim hover:text-gold-bright flex items-center justify-between">
            <span>📖 Reference &amp; Log</span>
            <span class="text-xs text-mute">click to collapse</span>
          </summary>
          <div class="px-3 pb-3 border-t border-border space-y-3 pt-3">
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Mods that can roll on this base</div>
              <div id="mod-pool-summary" class="text-xs text-dim">
                <div class="text-mute">Pick a base to see its pool.</div>
              </div>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Crafting Log <span id="history-count" class="text-mute">(0)</span></div>
              <ol id="history-list" class="text-sm space-y-1 max-h-40 overflow-y-auto">
                <li class="text-mute">No actions yet.</li>
              </ol>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Glossary</div>
              <dl class="text-xs text-dim flex flex-wrap gap-x-4 gap-y-1">
                <div><dt class="text-fg inline">Prefix</dt> – left affix</div>
                <div><dt class="text-fg inline">Suffix</dt> – right affix</div>
                <div><dt class="text-fg inline">T1</dt> – best tier</div>
                <div><dt class="text-fg inline">ilvl</dt> – gates tier rolls</div>
                <div><dt class="text-fg inline">Omen</dt> – alters next craft</div>
                <div><dt class="text-fg inline">Corrupt</dt> – locks item</div>
              </dl>
            </div>
          </div>
        </details>

        <!-- Persistent activity log -->
        <div id="activity-log-panel" class="parchment p-3">
          <div class="flex items-center justify-between mb-1.5">
            <div class="text-xs uppercase tracking-wider text-mute font-semibold">
              Activity Log <span id="activity-log-count" class="text-mute">(0)</span>
            </div>
            <div class="flex items-center gap-2">
              <label class="flex items-center gap-1 text-xs text-mute cursor-pointer" title="Auto-scroll to newest message">
                <input id="activity-log-autoscroll" type="checkbox" checked class="accent-gold" />
                Auto
              </label>
              <button id="activity-log-clear" class="text-xs text-mute hover:text-gold-bright" title="Clear the activity log">
                Clear
              </button>
            </div>
          </div>
          <ol id="activity-log-list" class="text-xs space-y-0.5 max-h-48 overflow-y-auto font-mono">
            <li class="text-mute italic">No activity yet. Apply a currency to see what happens.</li>
          </ol>
        </div>
      </div>

      <!-- RIGHT: Currency + reference -->
      <div class="space-y-3 min-w-0">
        <!-- Currency action bar -->
        <div class="parchment p-3">
          <div class="flex items-center justify-between mb-2">
            <div class="text-xs uppercase tracking-wider text-mute font-semibold">Apply</div>
            <div class="flex items-center gap-2">
              <button id="import-btn" class="text-xs text-gold hover:text-gold-bright">Import Item</button>
              <button id="open-omens-btn" class="text-xs text-gold hover:text-gold-bright">
                <span id="omens-btn-label">+ Add Omens</span>
              </button>
            </div>
          </div>
          <div id="currency-strip" class="grid grid-cols-[repeat(auto-fill,minmax(72px,1fr))] gap-1.5"></div>

          <!-- Cost tracking panel -->
          <div id="cost-panel" class="mt-2 border-t border-border pt-2 hidden">
            <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1.5">Craft Cost</div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs">
              <div><span class="text-dim">Chaos:</span> <span id="cost-chaos" class="text-gold-bright font-semibold">0</span></div>
              <div><span class="text-dim">Exalted:</span> <span id="cost-exalted" class="text-gold-bright font-semibold">0</span></div>
              <div><span class="text-dim">Divine:</span> <span id="cost-divine" class="text-gold-bright font-semibold">0</span></div>
              <div class="hidden" id="cost-fallback-badge"><span class="text-corrupted text-[10px]">(prices may be stale)</span></div>
            </div>
            <div id="cost-breakdown" class="mt-1.5 text-[10px] text-dim max-h-28 overflow-y-auto space-y-0.5"></div>
          </div>
          <div class="text-xs text-mute mt-2">Tip: keyboard shortcuts work when an item is selected - <span class="font-mono text-gold">T A R E X C D Z</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Omen picker modal -->
  <div id="omen-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="parchment w-full max-w-2xl max-h-[85vh] flex flex-col">
      <div class="sticky top-0 z-10 bg-bg-card border-b border-border p-4 rounded-t">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="!m-0">Pick Omens</h3>
            <p class="text-xs text-mute mt-1">Toggle omens to alter your next craft. They expire after one use.</p>
          </div>
          <button id="close-omen-modal" class="text-2xl text-mute hover:text-gold-bright leading-none" aria-label="Close omen picker">×</button>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <input id="omen-search" type="text" placeholder="Search omens…" class="flex-1 bg-bg border border-border-strong rounded px-3 py-1.5 text-sm focus:outline-none focus:border-gold" />
          <button id="omen-clear-all" class="btn text-xs">Clear</button>
        </div>
      </div>
      <div id="omen-modal-body" class="p-4 overflow-y-auto flex-1"></div>
      <div class="p-4 border-t border-border flex items-center justify-between bg-bg-card rounded-b">
        <span id="omen-modal-count" class="text-xs text-mute">0 selected</span>
        <button id="omen-done" class="btn btn-gold">Done</button>
      </div>
    </div>
  </div>

  <!-- Paste item modal -->
  <div id="paste-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="parchment w-full max-w-xl max-h-[85vh] flex flex-col">
      <div class="flex items-center justify-between border-b border-border p-4">
        <div>
          <h3 class="!m-0">Paste an Item</h3>
          <p class="text-xs text-mute mt-1">Copy an item in PoE2 (Ctrl+C) and paste it here.</p>
        </div>
        <button id="close-paste-modal" class="text-2xl text-mute hover:text-gold-bright leading-none" aria-label="Close paste modal">x</button>
      </div>
      <div class="p-4 flex-1">
        <textarea id="paste-textarea" class="w-full h-64 bg-bg border border-border-strong rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-gold resize-none" placeholder='Paste your PoE2 item text here...
e.g.:
Item Class: Rings
Rarity: Rare
Wrath Eye Prismatic Ring
--------
Item Level: 75
--------
Adds 3 to 6 Physical Damage to Attacks
+39% to Cold Resistance'></textarea>
        <div id="paste-preview" class="mt-3 hidden">
          <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Detected</div>
          <div id="paste-detected" class="text-sm text-fg space-y-1"></div>
        </div>
        <div id="paste-error" class="mt-3 hidden">
          <div class="text-xs text-corrupted">Could not parse item text. Make sure you copied an item in PoE2 (Ctrl+C).</div>
        </div>
      </div>
      <div class="border-t border-border p-4 flex items-center justify-between bg-bg-card rounded-b">
        <span id="paste-hint" class="text-xs text-mute">Paste with Ctrl+V or right-click</span>
        <div class="flex gap-2">
          <button id="paste-cancel" class="btn text-xs">Cancel</button>
          <button id="paste-import" class="btn btn-gold text-xs" disabled>Import Item</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom tooltip -->
  <div id="tooltip" class="tooltip-pop"></div>

  <!-- Paste modal -->
  <div id="paste-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="parchment w-full max-w-2xl max-h-[85vh] flex flex-col">
      <div class="sticky top-0 z-10 bg-bg-card border-b border-border p-4 rounded-t">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="!m-0">Paste Item from PoE 2</h3>
            <p class="text-xs text-mute mt-1">Copy an item in-game (Ctrl+C) and paste it below.</p>
          </div>
          <button id="close-paste-modal" class="text-2xl text-mute hover:text-gold-bright leading-none" aria-label="Close paste modal">&times;</button>
        </div>
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <textarea id="paste-textarea" rows="12" class="w-full bg-bg border border-border-strong rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-gold" placeholder="Paste your item text here...&#10;&#10;Example:&#10;Item Class: Rings&#10;Rarity: Rare&#10;Torment Whorl&#10;Gold Ring&#10;..."></textarea>
        <div id="paste-preview" class="mt-2 hidden">
          <div id="paste-detected" class="text-sm text-fg"></div>
          <div id="paste-error" class="text-xs text-corrupted mt-1"></div>
        </div>
      </div>
      <div class="p-4 border-t border-border flex items-center justify-between bg-bg-card rounded-b">
        <span class="text-xs text-mute">Paste your in-game item copy above, then click Import.</span>
        <div class="flex gap-2">
          <button id="cancel-paste-btn" class="btn text-xs">Cancel</button>
          <button id="import-paste-btn" class="btn btn-gold text-xs hidden">Import Item</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Base options data (small, rendered for dropdown) -->
  <script type="application/json" id="base-data" set:html={JSON.stringify(baseOptions)} />

  <!-- i18n strings -->
  <script type="application/json" id="i18n-data" set:html={i18nStrings} />

  <script>
    import { applyOperation, emptyItem, getCurrencyAvailability, OPERATIONS } from '~/lib/emulator';
    import { costTracker } from '~/lib/cost-tracker';
    import { guidanceFor, eligibleModCount } from '~/lib/expected-cost';

    const basesData = JSON.parse(document.getElementById('base-data')!.textContent || '[]');
    const i18n = JSON.parse(document.getElementById('i18n-data')!.textContent || '{}');
    
    // These will be populated by fetch
    let currencyData: any[] = [];
    let omensData: any[] = [];
    let modsData: any[] = [];
    let weightsData: any[] = [];
    let dataLoaded = false;
    let dataLoadCallbacks: Array<() => void> = [];

    function onDataLoaded(cb: () => void) {
      if (dataLoaded) { cb(); return; }
      dataLoadCallbacks.push(cb);
    }

    // Fetch all data files in parallel
    async function loadData() {
      // If data was already provided externally (e.g. by an e2e test), skip fetch
      if (window.__e2eData) {
        currencyData = window.__e2eData.currency;
        omensData = window.__e2eData.omens;
        modsData = window.__e2eData.mods;
        weightsData = window.__e2eData.weights;
        dataLoaded = true;
        document.getElementById('loading-state')!.classList.add('hidden');
        document.getElementById('empty-state')!.classList.remove('hidden');
        for (const cb of dataLoadCallbacks) cb();
        dataLoadCallbacks = [];
        return;
      }
      try {
        const [currencyRes, omensRes, modsRes, weightsRes] = await Promise.all([
          fetch('/data/currency.json'),
          fetch('/data/omens.json'),
          fetch('/data/mods.json'),
          fetch('/data/weights.json'),
        ]);
        if (!currencyRes.ok || !omensRes.ok || !modsRes.ok || !weightsRes.ok) {
          throw new Error('Failed to load data files');
        }
        currencyData = await currencyRes.json();
        omensData = await omensRes.json();
        modsData = await modsRes.json();
        weightsData = await weightsRes.json();
        dataLoaded = true;
        
        // Hide loading state, show empty state
        document.getElementById('loading-state')!.classList.add('hidden');
        document.getElementById('empty-state')!.classList.remove('hidden');
        
        // Fire pending callbacks
        for (const cb of dataLoadCallbacks) cb();
        dataLoadCallbacks = [];
      } catch (err) {
        console.error('Failed to load data:', err);
        document.getElementById('loading-state')!.innerHTML = `
          <div class="text-3xl mb-2">❌</div>
          <div class="font-display text-xl text-fg mb-1">Failed to load data</div>
          <p class="text-sm text-dim">${err instanceof Error ? err.message : 'Unknown error'}</p>
          <button onclick="location.reload()" class="btn btn-gold mt-4">Retry</button>
        `;
      }
    }
    loadData();

    type BaseOpt = typeof basesData[number];
    type CurOpt = { id: string; name: string; category: string; tier: string; imageUrl: string; description: string; };
