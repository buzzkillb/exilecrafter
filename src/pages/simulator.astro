---
import Base from '~/layouts/Base.astro';
import { bases } from '~/lib/data';
import { useT } from '~/lib/i18n';

const locale = (Astro.locals.locale as 'en' | 'pt') ?? 'en';
const t = useT(locale);

const baseOptions = bases.map((b) => ({
  id: b.id, name: b.name, slot: b.slot, level: b.level,
  affixSlots: b.affixSlots, imageUrl: b.imageUrl, variant: b.variant,
}));

// Crafting examples — curated base + description + suggested goal
const craftingExamples = [
  {
    id: bases.find((b) => b.name === 'Sapphire')?.id || '',
    name: 'Sapphire Jewel',
    tag: '💎 Expert',
    description: 'Craft a top-tier jewel using Essences, Liquid Emotions, Desecration & Fracturing.',
    goal: '5-mod jewel with 40-60% increased Effect of Suffixes',
    difficulty: 'expert',
  },
  {
    id: bases.find((b) => b.name === 'Ancestral Tiara')?.id || '',
    name: 'Ancestral Tiara',
    tag: '🎯 Endgame',
    description: 'High-end Energy Shield helmet. Roll life, resistances, and mana with real tier gates.',
    goal: '3P/3S ES helmet at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Flying Spear')?.id || '',
    name: 'Flying Spear',
    tag: '🗡️ Weapon',
    description: 'One-handed spear with physical damage, attack speed, and crit chance.',
    goal: '3P/3S DPS weapon at ilvl 78',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Gold Amulet')?.id || '',
    name: 'Gold Amulet',
    tag: '📿 Amulet',
    description: 'High-end jewellery base with increased Rarity of Items Found. Roll life, resists, spirit.',
    goal: '3P/2S magic-find amulet at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Gold Ring')?.id || '',
    name: 'Gold Ring',
    tag: '💍 Rings',
    description: 'Top-tier ring base with innate increased rarity. Roll resists, damage, attributes.',
    goal: '2P/2S MF ring at ilvl 80 for mapping',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Two-Stone Ring')?.id || '',
    name: 'Two-Stone Ring',
    tag: '💍 Rings',
    description: 'Versatile leveling ring with dual elemental resistances. Easy to craft.',
    goal: '2P/2S ring for early endgame',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Tasalian Greaves')?.id || '',
    name: 'Tasalian Greaves',
    tag: '👢 Boots',
    description: 'High-end evasion/ES boots. Roll movement speed, resistances, and attributes.',
    goal: '2P/2S endgame boots at ilvl 80',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Waystone (Tier 16)')?.id || '',
    name: 'Waystone (Tier 16)',
    tag: '🗺️ Map',
    description: 'Endgame waystone. Mod quantity, rarity, pack size for maximum loot.',
    goal: 'Max-rolled T16 waystone for juiced mapping',
    difficulty: 'advanced',
  },
  {
    id: bases.find((b) => b.name === 'Warlord Cuirass')?.id || '',
    name: 'Warlord Cuirass',
    tag: '🛡️ Armour',
    description: 'High-level body armour. Roll life, resistances, and armour/ES hybrid mods.',
    goal: '3P/3S endgame chest at ilvl 80',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Solar Amulet')?.id || '',
    name: 'Solar Amulet',
    tag: '📿 Mid-Level',
    description: 'All-around amulet craft. Roll +spirit, resistances, and attributes.',
    goal: '2P/2S amulet at ilvl 30',
    difficulty: 'intermediate',
  },
  {
    id: bases.find((b) => b.name === 'Broadhead Quiver')?.id || '',
    name: 'Broadhead Quiver',
    tag: '🏹 Quiver',
    description: 'Budget quiver craft. Roll increased damage, attack speed, and crit chance.',
    goal: '2P/2S damage quiver at ilvl 1',
    difficulty: 'beginner',
  },
  {
    id: bases.find((b) => b.name === 'Iron Ring')?.id || '',
    name: 'Iron Ring',
    tag: '⭕ Beginner',
    description: 'Simple ring to learn the basics. Alchemy, Essences, and Chaos spam.',
    goal: '2P/2S starter ring at ilvl 1',
    difficulty: 'beginner',
  },
].filter((ex) => ex.id);

---

<Base title={`${t('simulator.title')} - Exile Crafter`}>
  <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
    <h1 class="!m-0">Simulator</h1>
    <div class="flex items-center gap-2 min-w-0 flex-1 sm:flex-initial">
      <select id="base-picker" class="bg-bg border border-border-strong rounded px-3 py-1.5 text-sm focus:outline-none focus:border-gold min-w-0 flex-1 sm:flex-initial sm:w-72">
        <option value="">Choose a base…</option>
      </select>
      <label class="flex items-center gap-1 text-xs text-mute" title="Item level - gates which tiers can roll">
        ilvl
        <input id="ilvl-input" type="number" value="80" min="1" max="100" class="w-14 bg-bg border border-border-strong rounded px-2 py-1.5 text-sm focus:outline-none focus:border-gold" />
      </label>
    </div>
  </div>

  <div class="max-w-5xl mx-auto">
    <!-- Loading state -->
    <div id="loading-state" class="parchment p-6 text-center">
      <div class="text-3xl mb-2">⏳</div>
      <div class="font-display text-xl text-fg mb-1">Loading data…</div>
      <p class="text-sm text-dim">Fetching mods, currencies, and omens from the database.</p>
    </div>

    <!-- Empty state with quick picks -->
    <div id="empty-state" class="hidden parchment p-6 text-center">
      <div class="text-3xl mb-2">⚒️</div>
      <div class="font-display text-xl text-fg mb-1">Pick a base to start crafting</div>
      <p class="text-sm text-dim mb-4">Or try one of these popular starters:</p>
      <div class="mb-4">
        <button id="paste-empty-btn" class="btn text-sm px-4 py-2 border border-gold/40 text-gold hover:bg-gold/10 rounded-lg transition-all">
          📋 Paste an item from your clipboard
        </button>
      </div>
      <div id="quick-picks" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 justify-center">
        {craftingExamples.map((ex) => {
          const b = bases.find((x) => x.id === ex.id);
          const difficultyColors: Record<string, string> = {
            beginner: 'border-green-700/40 text-green-400',
            intermediate: 'border-blue-700/40 text-blue-400',
            advanced: 'border-purple-700/40 text-purple-400',
            expert: 'border-gold/40 text-gold',
          };
          const diffCls = difficultyColors[ex.difficulty] || 'border-border text-mute';
          return b ? (
            <button class="flex flex-col items-start gap-1 p-3 border rounded-lg text-left transition-all hover:border-gold hover:bg-bg-card/60 cursor-pointer w-full quick-pick-btn" data-base={b.id} data-name={b.name}>
              <div class="flex items-center gap-2 w-full">
                {b.imageUrl && <img src={b.imageUrl} alt="" class="w-7 h-7 shrink-0" />}
                <span class="font-semibold text-sm text-fg leading-tight">{ex.name}</span>
                <span class="ml-auto text-[10px] font-medium uppercase tracking-wide px-1.5 py-0.5 rounded border {diffCls}">{ex.tag}</span>
              </div>
              <p class="text-[11px] text-dim leading-relaxed">{ex.description}</p>
              <span class="text-[10px] text-mute italic">→ {ex.goal}</span>
            </button>
          ) : null;
        })}
      </div>
    </div>

    <div id="main-ui" class="hidden grid lg:grid-cols-[1fr_360px] gap-3">
      <!-- LEFT: Item + history -->
      <div class="space-y-3 min-w-0">
        <!-- Item display -->
        <div id="item-display" class="parchment p-3"></div>

        <!-- Cost tracking bar — below item, above tips -->
        <div id="cost-panel" class="flex items-center gap-3 parchment px-4 py-2 hidden">
          <span class="text-[10px] uppercase tracking-wider text-mute font-semibold">Cost</span>
          <span class="flex items-center gap-1.5 text-xs font-mono">
            <span class="text-dim">Chaos:</span>
            <span id="cost-chaos" class="text-gold-bright font-semibold">0</span>
          </span>
          <span class="flex items-center gap-1.5 text-xs font-mono">
            <span class="text-dim">Exalted:</span>
            <span id="cost-exalted" class="text-gold-bright font-semibold">0</span>
          </span>
          <span class="flex items-center gap-1.5 text-xs font-mono">
            <span class="text-dim">Divine:</span>
            <span id="cost-divine" class="text-gold-bright font-semibold">0</span>
          </span>
          <div class="hidden" id="cost-fallback-badge"><span class="text-corrupted text-[10px]">(prices may be stale)</span></div>
          <div id="cost-breakdown" class="ml-auto text-[10px] text-dim max-h-20 overflow-y-auto space-y-0.5 hidden"></div>
        </div>

        <!-- Active omens strip -->
        <div id="active-omens-strip" class="parchment p-2 hidden">
          <div class="flex items-center justify-between mb-1.5">
            <div class="text-xs uppercase tracking-wider text-gold font-semibold">Active Omens</div>
            <button id="clear-omens-btn" class="text-xs text-mute hover:text-gold-bright">Clear all</button>
          </div>
          <div id="active-omens-chips" class="flex flex-wrap gap-1.5"></div>
          <div class="text-xs text-mute mt-1">These alter your next currency action, then expire.</div>
        </div>

        <!-- Tips -->
        <div id="tips-panel" class="parchment p-3 text-sm"></div>

        <!-- Quick action bar -->
        <div class="flex gap-2">
          <button id="undo-btn" class="btn text-xs flex-1" title="Undo last craft [Z]" aria-label="Undo last craft">
            ↶ Undo
          </button>
          <button id="copy-btn" class="btn text-xs flex-1" title="Copy item to clipboard" aria-label="Copy item to clipboard">
            📋 Copy
          </button>
          <button id="paste-btn" class="btn text-xs flex-1" title="Paste an item from in-game copy" aria-label="Paste an item">
            📋 Paste
          </button>
          <button id="seed-rare-btn" class="btn text-xs flex-1" title="Jump straight to a 6-mod Rare (Alchemy + 2 Exalts)" aria-label="Seed a Rare item">
            ⚡ Seed Rare
          </button>
          <button id="reset-btn" class="btn text-xs flex-1" title="Reset to a fresh Normal item" aria-label="Reset item">
            ↺ Reset
          </button>
        </div>

        <!-- Reference & Log (always expanded, above activity log) -->
        <details class="parchment" open>
          <summary class="p-3 cursor-pointer text-sm text-fg-dim hover:text-gold-bright flex items-center justify-between">
            <span>📖 Reference &amp; Log</span>
            <span class="text-xs text-mute">click to collapse</span>
          </summary>
          <div class="px-3 pb-3 border-t border-border space-y-3 pt-3">
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Mods that can roll on this base</div>
              <div id="mod-pool-summary" class="text-xs text-dim">
                <div class="text-mute">Pick a base to see its pool.</div>
              </div>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Crafting Log <span id="history-count" class="text-mute">(0)</span></div>
              <ol id="history-list" class="text-sm space-y-1 max-h-40 overflow-y-auto">
                <li class="text-mute">No actions yet.</li>
              </ol>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Glossary</div>
              <dl class="text-xs text-dim flex flex-wrap gap-x-4 gap-y-1">
                <div><dt class="text-fg inline">Prefix</dt> – left affix</div>
                <div><dt class="text-fg inline">Suffix</dt> – right affix</div>
                <div><dt class="text-fg inline">T1</dt> – best tier</div>
                <div><dt class="text-fg inline">ilvl</dt> – gates tier rolls</div>
                <div><dt class="text-fg inline">Omen</dt> – alters next craft</div>
                <div><dt class="text-fg inline">Corrupt</dt> – locks item</div>
              </dl>
            </div>
          </div>
        </details>

        <!-- Persistent activity log -->
        <div id="activity-log-panel" class="parchment p-3">
          <div class="flex items-center justify-between mb-1.5">
            <div class="text-xs uppercase tracking-wider text-mute font-semibold">
              Activity Log <span id="activity-log-count" class="text-mute">(0)</span>
            </div>
            <div class="flex items-center gap-2">
              <label class="flex items-center gap-1 text-xs text-mute cursor-pointer" title="Auto-scroll to newest message">
                <input id="activity-log-autoscroll" type="checkbox" checked class="accent-gold" />
                Auto
              </label>
              <button id="activity-log-clear" class="text-xs text-mute hover:text-gold-bright" title="Clear the activity log">
                Clear
              </button>
            </div>
          </div>
          <ol id="activity-log-list" class="text-xs space-y-0.5 max-h-48 overflow-y-auto font-mono">
            <li class="text-mute italic">No activity yet. Apply a currency to see what happens.</li>
          </ol>
        </div>
      </div>

      <!-- RIGHT: Currency + reference -->
      <div class="space-y-3 min-w-0">
        <!-- Currency action bar -->
        <div class="parchment p-3">
          <div class="flex items-center justify-between mb-2">
            <div class="text-xs uppercase tracking-wider text-mute font-semibold">Apply</div>
            <div class="flex items-center gap-2">
              <button id="open-omens-btn" class="text-xs text-gold hover:text-gold-bright">
                <span id="omens-btn-label">+ Add Omens</span>
              </button>
            </div>
          </div>
          <div id="currency-strip" class="grid grid-cols-[repeat(auto-fill,minmax(72px,1fr))] gap-1.5"></div>


          <div class="text-xs text-mute mt-2">Tip: keyboard shortcuts work when an item is selected - <span class="font-mono text-gold">T A R E X C D Z</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Omen picker modal -->
  <div id="omen-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="parchment w-full max-w-2xl max-h-[85vh] flex flex-col">
      <div class="sticky top-0 z-10 bg-bg-card border-b border-border p-4 rounded-t">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="!m-0">Pick Omens</h3>
            <p class="text-xs text-mute mt-1">Toggle omens to alter your next craft. They expire after one use.</p>
          </div>
          <button id="close-omen-modal" class="text-2xl text-mute hover:text-gold-bright leading-none" aria-label="Close omen picker">×</button>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <input id="omen-search" type="text" placeholder="Search omens…" class="flex-1 bg-bg border border-border-strong rounded px-3 py-1.5 text-sm focus:outline-none focus:border-gold" />
          <button id="omen-clear-all" class="btn text-xs">Clear</button>
        </div>
      </div>
      <div id="omen-modal-body" class="p-4 overflow-y-auto flex-1"></div>
      <div class="p-4 border-t border-border flex items-center justify-between bg-bg-card rounded-b">
        <span id="omen-modal-count" class="text-xs text-mute">0 selected</span>
        <button id="omen-done" class="btn btn-gold">Done</button>
      </div>
    </div>
  </div>

  <!-- Paste item modal -->
  <div id="paste-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="parchment w-full max-w-xl max-h-[85vh] flex flex-col">
      <div class="flex items-center justify-between border-b border-border p-4">
        <div>
          <h3 class="!m-0">Paste an Item</h3>
          <p class="text-xs text-mute mt-1">Copy an item in PoE2 (Ctrl+C) and paste it here.</p>
        </div>
        <button id="close-paste-modal" class="text-2xl text-mute hover:text-gold-bright leading-none" aria-label="Close paste modal">x</button>
      </div>
      <div class="p-4 flex-1">
        <textarea id="paste-textarea" class="w-full h-64 bg-bg border border-border-strong rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-gold resize-none" placeholder='Paste your PoE2 item text here...
e.g.:
Item Class: Rings
Rarity: Rare
Wrath Eye Prismatic Ring
--------
Item Level: 75
--------
Adds 3 to 6 Physical Damage to Attacks
+39% to Cold Resistance'></textarea>
        <div id="paste-preview" class="mt-3 hidden">
          <div class="text-xs uppercase tracking-wider text-mute font-semibold mb-1">Detected</div>
          <div id="paste-detected" class="text-sm text-fg space-y-1"></div>
        </div>
        <div id="paste-error" class="mt-3 hidden">
          <div class="text-xs text-corrupted">Could not parse item text. Make sure you copied an item in PoE2 (Ctrl+C).</div>
        </div>
      </div>
      <div class="border-t border-border p-4 flex items-center justify-between bg-bg-card rounded-b">
        <span id="paste-hint" class="text-xs text-mute">Paste with Ctrl+V or right-click</span>
        <div class="flex gap-2">
          <button id="paste-cancel" class="btn text-xs">Cancel</button>
          <button id="paste-import" class="btn btn-gold text-xs" disabled>Import Item</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom tooltip -->
<div id="tooltip" class="tooltip-pop"></div>

  <!-- Base options data (small, rendered for dropdown) -->
  <script type="application/json" id="base-data" set:html={JSON.stringify(baseOptions)} />

  <script>
    import { applyOperation, emptyItem, getCurrencyAvailability, OPERATIONS } from '~/lib/emulator';
    import { costTracker } from '~/lib/cost-tracker';
    import { guidanceFor, eligibleModCount } from '~/lib/expected-cost';

    const basesData = JSON.parse(document.getElementById('base-data')!.textContent || '[]');

    // Module-scope lookup tables — built once, reused on every render.
    const RARITY_COLORS: Record<string, string> = {
      normal: '#c8c8c8', magic: '#8888ff', rare: '#ffff77', unique: '#af6025',
    };
    const SLOT_LABELS: Record<string, string> = {
      helmet: 'Helmet', body_armour: 'Body Armour', gloves: 'Gloves',
      boots: 'Boots', belt: 'Belt', amulet: 'Amulet', ring: 'Ring',
      shield: 'Shield', quiver: 'Quiver', focus: 'Focus',
      weapon_1h: 'One Handed Weapon', weapon_2h: 'Two Handed Weapon',
      flask: 'Flask', charm: 'Charm', jewel: 'Jewel',
      waystone: 'Waystone', tablet: 'Tablet', relic: 'Relic',
    };
    // Map from mod tag → display color (checked in priority order).
    const TAG_COLOR_RULES: Array<[string[], string]> = [
      [['fire'], '#c44a2a'],
      [['cold'], '#4a8fc4'],
      [['lightning'], '#d4c84a'],
      [['chaos'], '#a04ac4'],
      [['physical'], '#c9a87a'],
      [['life'], '#d44a4a'],
      [['mana'], '#4a6fc4'],
      [['energy_shield', 'ward'], '#6accc4'],
      [['elemental', 'damage'], '#c9a14a'],
      [['attack'], '#c97070'],
      [['speed', 'critical'], '#d4c84a'],
      [['caster'], '#8888ff'],
      [['minion'], '#a08ac4'],
    ];
    const TAG_COLOR_DEFAULT = '#a89a7d';
    function tagColor(tags: string[]): string {
      for (const [needles, color] of TAG_COLOR_RULES) {
        if (needles.some((n) => tags.includes(n))) return color;
      }
      return TAG_COLOR_DEFAULT;
    }
    function capitalize(s: string): string {
      return s ? s.charAt(0).toUpperCase() + s.slice(1) : '';
    }

// Populated by fetch
    let currencyData: any[] = [];
    let omensData: any[] = [];
    let modsData: any[] = [];
    let weightsData: any[] = [];

    // Fetch all data files in parallel
    async function loadData() {
      // If data was already provided externally (e.g. by an e2e test), skip fetch
      if (window.__e2eData) {
        currencyData = window.__e2eData.currency;
        omensData = window.__e2eData.omens;
        modsData = window.__e2eData.mods;
        weightsData = window.__e2eData.weights;
        finishLoad();
        return;
      }
      try {
        const [currencyRes, omensRes, modsRes, weightsRes] = await Promise.all([
          fetch('/data/currency.json'),
          fetch('/data/omens.json'),
          fetch('/data/mods.json'),
          fetch('/data/weights.json'),
        ]);
        if (!currencyRes.ok || !omensRes.ok || !modsRes.ok || !weightsRes.ok) {
          throw new Error('Failed to load data files');
        }
        currencyData = await currencyRes.json();
        omensData = await omensRes.json();
        modsData = await modsRes.json();
        weightsData = await weightsRes.json();
        finishLoad();
      } catch (err) {
        console.error('Failed to load data:', err);
        document.getElementById('loading-state')!.innerHTML = `
          <div class="text-3xl mb-2">❌</div>
          <div class="font-display text-xl text-fg mb-1">Failed to load data</div>
          <p class="text-sm text-dim">${err instanceof Error ? err.message : 'Unknown error'}</p>
          <button onclick="location.reload()" class="btn btn-gold mt-4">Retry</button>
        `;
      }
    }
    loadData();

    type BaseOpt = typeof basesData[number];
    type CurOpt = { id: string; name: string; category: string; tier: string; imageUrl: string; description: string; };
    type OmenOpt = { id: string; name: string; effect: string; appliesTo: string[]; imageUrl: string; };
    type ModOpt = { id: string; name: string; type: string; domain: string[]; tier: number; level: number; tags: string[]; description: string; };

    const basePicker = document.getElementById('base-picker') as HTMLSelectElement;
    const ilvlInput = document.getElementById('ilvl-input') as HTMLInputElement;
    const itemDisplay = document.getElementById('item-display')!;
    const currencyStrip = document.getElementById('currency-strip')!;
    const historyList = document.getElementById('history-list')!;
    const historyCount = document.getElementById('history-count')!;
    const activityLogList = document.getElementById('activity-log-list')!;
    const activityLogCount = document.getElementById('activity-log-count')!;
    const activityLogClear = document.getElementById('activity-log-clear')! as HTMLButtonElement;
    const activityLogAutoscroll = document.getElementById('activity-log-autoscroll')! as HTMLInputElement;
    const costPanel = document.getElementById('cost-panel');
    const costChaos = document.getElementById('cost-chaos');
    const costExalted = document.getElementById('cost-exalted');
    const costDivine = document.getElementById('cost-divine');
    const costBreakdown = document.getElementById('cost-breakdown');
    const costFallbackBadge = document.getElementById('cost-fallback-badge');
    const tipsPanel = document.getElementById('tips-panel')!;
    const modPoolSummary = document.getElementById('mod-pool-summary')!;
    const activeOmensStrip = document.getElementById('active-omens-strip')!;
    const activeOmensChips = document.getElementById('active-omens-chips')!;
    const omensBtnLabel = document.getElementById('omens-btn-label')!;
    const emptyState = document.getElementById('empty-state')!;
    const mainUi = document.getElementById('main-ui')!;
    const loadingState = document.getElementById('loading-state')!;

    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const seedRareBtn = document.getElementById('seed-rare-btn') as HTMLButtonElement;
    const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
    const clearOmensBtn = document.getElementById('clear-omens-btn') as HTMLButtonElement;
    const openOmensBtn = document.getElementById('open-omens-btn') as HTMLButtonElement;

    const omenModal = document.getElementById('omen-modal')!;
    const omenModalBody = document.getElementById('omen-modal-body')!;
    const omenModalCount = document.getElementById('omen-modal-count')!;
    const omenSearch = document.getElementById('omen-search') as HTMLInputElement;
    const omenClearAll = document.getElementById('omen-clear-all') as HTMLButtonElement;
    const omenDone = document.getElementById('omen-done') as HTMLButtonElement;
    const closeOmenModal = document.getElementById('close-omen-modal') as HTMLButtonElement;
    const tooltip = document.getElementById('tooltip')!;

    // Populate base picker
    for (const b of basesData as BaseOpt[]) {
      const opt = document.createElement('option');
      opt.value = b.id;
      opt.textContent = `${b.name} (${b.slot.replace(/_/g, ' ')})`;
      basePicker.appendChild(opt);
    }

    // Quick pick buttons
    document.querySelectorAll<HTMLButtonElement>('.quick-pick-btn').forEach((b) => {
      b.addEventListener('click', () => {
        const id = b.dataset.base!;
        basePicker.value = id;
        selectBase(id);
      });
    });

    let currentBase: BaseOpt | null = null;
    let currentItem: any = null;
    let history: any[] = [];
    const activeOmens = new Set<string>();

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
    }

    /** Persistent activity log */
    let activityLog: { ts: number; msg: string; kind: 'ok' | 'error' | 'info' }[] = [];

    function logActivity(msg: string, kind: 'ok' | 'error' | 'info' = 'info') {
      activityLog.push({ ts: Date.now(), msg, kind });
      if (activityLog.length > 200) activityLog.splice(0, activityLog.length - 200);
      renderActivityLog();
    }

    function renderActivityLog() {
      activityLogCount.textContent = `(${activityLog.length})`;
      if (activityLog.length === 0) {
        activityLogList.innerHTML = '<li class="text-mute italic">No activity yet. Apply a currency to see what happens.</li>';
        return;
      }
      activityLogList.innerHTML = activityLog.slice().reverse().map((entry) => {
        const time = new Date(entry.ts).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const colorCls = entry.kind === 'ok' ? 'text-gold' : entry.kind === 'error' ? 'text-corrupted' : 'text-dim';
        return `<li class="border-b border-border/40 pb-0.5 flex gap-2"><span class="text-mute shrink-0">${time}</span><span class="${colorCls} flex-1 break-words">${escapeHtml(entry.msg)}</span></li>`;
      }).join('');
      if (activityLogAutoscroll.checked) {
        activityLogList.scrollTop = 0;
      }
    }

    activityLogClear.addEventListener('click', () => {
      activityLog = [];
      renderActivityLog();
    });

    function flash(msg: string, kind: 'ok' | 'error' = 'error') {
      logActivity(msg, kind);
      const el = document.createElement('div');
      el.className = `fixed top-20 left-1/2 -translate-x-1/2 z-50 parchment px-4 py-2 text-sm border ${kind === 'ok' ? 'border-gold' : 'border-corrupted'}`;
      el.textContent = msg;
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 2000);
    }

    // Custom tooltip
    function positionTooltip(x: number, y: number) {
      const tipRect = tooltip.getBoundingClientRect();
      const offset = 14;
      let left = x + offset;
      let top = y + offset;
      if (left + tipRect.width > window.innerWidth - 8) left = x - tipRect.width - offset;
      if (top + tipRect.height > window.innerHeight - 8) top = y - tipRect.height - offset;
      if (left < 8) left = 8;
      if (top < 8) top = 8;
      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
    }
    function showTooltip(target: HTMLElement, html: string, e?: MouseEvent) {
      tooltip.innerHTML = html;
      tooltip.style.display = 'block';
      if (e) {
        positionTooltip(e.clientX, e.clientY);
      } else {
        const rect = target.getBoundingClientRect();
        positionTooltip(rect.left + rect.width / 2, rect.top + rect.height / 2);
      }
    }
    function hideTooltip() {
      tooltip.style.display = 'none';
    }
    function attachTooltip(el: HTMLElement, html: string) {
      el.addEventListener('mouseenter', (e) => showTooltip(el, html, e as MouseEvent));
      el.addEventListener('mousemove', (e) => positionTooltip(e.clientX, e.clientY));
      el.addEventListener('mouseleave', hideTooltip);
      el.addEventListener('focus', (e) => showTooltip(el, html, e as MouseEvent));
      el.addEventListener('blur', hideTooltip);
    }

    // --- Paste / Copy item clipboard support ---
    const pasteEmptyBtn = document.getElementById('paste-empty-btn') as HTMLButtonElement;
    const pasteBtn = document.getElementById('paste-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const pasteImport = document.getElementById('paste-import') as HTMLButtonElement;
    const pasteCancel = document.getElementById('paste-cancel') as HTMLButtonElement;
    const closePasteModal = document.getElementById('close-paste-modal') as HTMLButtonElement;

    /** Find the closest matching base by name (fuzzy match: exact > endsWith > includes) */
    function findBaseByName(name: string) {
      const n = name.toLowerCase().trim();
      // Exact match
      let b = basesData.find((x: any) => x.name.toLowerCase() === n);
      if (b) return b;
      // Ends with (most common: "Wrath Eye Prismatic Ring" ends with "Prismatic Ring")
      b = basesData.find((x: any) => n.endsWith(x.name.toLowerCase()));
      if (b) return b;
      // Base name is contained in the pasted name
      b = basesData.find((x: any) => n.includes(x.name.toLowerCase()));
      if (b) return b;
      // Pasted name is contained in base name
      b = basesData.find((x: any) => x.name.toLowerCase().includes(n));
      if (b) return b;
      return null;
    }

    let parsedPaste: any = null;

    
    const pasteModal = document.getElementById('paste-modal');
const pasteTextarea = document.getElementById('paste-textarea');
    const pastePreview = document.getElementById('paste-preview');
    const pasteDetected = document.getElementById('paste-detected');
    const pasteError = document.getElementById('paste-error');

function openPasteModal() {
      pasteTextarea.value = '';
      pastePreview.classList.add('hidden');
      pasteError.classList.add('hidden');
      pasteImport.disabled = true;
      parsedPaste = null;
      pasteModal.classList.remove('hidden');
      setTimeout(() => pasteTextarea.focus(), 100);
    }

    function closePasteModalFn() {
      pasteModal.classList.add('hidden');
    }

    function handlePasteText() {
      const text = pasteTextarea.value.trim();
      if (!text) {
        pastePreview.classList.add('hidden');
        pasteError.classList.add('hidden');
        pasteImport.disabled = true;
        parsedPaste = null;
        return;
      }
      // Parse the clipboard text. Two formats supported:
      //   Wiki/poe2db format: starts with "Item Class:" then "Rarity:" then mod headers
      //     like "{ Prefix Modifier "Tempered" (Tier: 2) — Damage, Physical, Attack }"
      //   In-game format (advanced descriptions ON): starts with "Rarity:" and uses
      //     simple mod headers like "Prefix Modifier" with tier indicators on
      //     their own lines ("T1", "T2", etc.) between mods.
      const lines = text.split(/\r?\n/);
      let idx = 0;
      function nextLine() {
        while (idx < lines.length) {
          const l = lines[idx++].trim();
          if (l.length > 0) return l;
        }
        return null;
      }
      // Validate header — either "Item Class:" (wiki) or "Rarity:" (in-game) is accepted
      let line = nextLine();
      if (!line) {
        pasteError.classList.remove('hidden');
        pastePreview.classList.add('hidden');
        pasteImport.disabled = true;
        parsedPaste = null;
        return;
      }
      pasteError.classList.add('hidden');

      let itemClass = '';
      if (line.startsWith('Item Class:')) {
        itemClass = line.slice('Item Class:'.length).trim();
        line = nextLine();
      }
      let rarity = 'rare';
      if (line && line.startsWith('Rarity:')) {
        rarity = line.slice('Rarity:'.length).trim().toLowerCase();
        line = nextLine();
      } else if (!line) {
        // No Rarity: header found at all — give up
        pasteError.classList.remove('hidden');
        pastePreview.classList.add('hidden');
        pasteImport.disabled = true;
        parsedPaste = null;
        return;
      }
      // In in-game format (no Item Class), the unique name and base are on
      // consecutive lines. The base line is usually a known base name. Read
      // both candidates and let findBaseByName disambiguate.
      const candidateName = line || 'Unknown';
      const nextCandidate = nextLine();
      const candidates = [candidateName];
      if (nextCandidate && !/^-{3,}$/.test(nextCandidate.trim()) && !/^Rarity:/i.test(nextCandidate)) {
        candidates.push(nextCandidate);
      }
      let name = candidateName;
      let itemLevel = 80;
      for (let i = idx; i < lines.length; i++) {
        const l = lines[i].trim();
        if (/^Item\s*Level:\s*\d+/i.test(l)) {
          itemLevel = parseInt(l.replace(/^Item\s*Level:\s*/i, ''));
          break;
        }
      }

      // Find matching base
      const baseNameParts = name.split(' ');
      let foundBase = null;
      // Explicit base resolution — no guessing. Both formats put the unique
      // name on one line and the base name on the next line:
      //   Wiki:  "Torment Whorl\nGold Ring"
      //   In-game: "Runeforged Whorl\nFocus"
      // The base is always on a separate line — we don't need fuzzy matching
      // against the unique name.
      if (candidates.length >= 2) {
        // Try the second candidate directly as the base name
        foundBase = findBaseByName(candidates[1]);
        if (foundBase) {
          name = candidates[0];
        }
      }
      // Fallback: if we still don't have a base, try the full unique name
      // (handles edge cases where the unique name itself IS a base, e.g. unique items)
      if (!foundBase) {
        foundBase = findBaseByName(name);
      }
      // Try slot-based search
      if (!foundBase) {
        const slotMap: Record<string, string> = {
          'amulets': 'amulet', 'belts': 'belt', 'body armours': 'body_armour',
          'boots': 'boots', 'bows': 'weapon_2h', 'charms': 'charm',
          'chest armours': 'body_armour', 'crossbows': 'weapon_2h',
          'flasks': 'flask', 'focus': 'focus', 'gloves': 'gloves',
          'helmets': 'helmet', 'jewels': 'jewel', 'quivers': 'quiver',
          'rings': 'ring', 'shields': 'shield', 'spears': 'weapon_1h',
          'staves': 'weapon_2h', 'wands': 'weapon_1h', 'waystones': 'waystone',
          'tablets': 'tablet', 'relics': 'relic',
          'one handed weapons': 'weapon_1h', 'two handed weapons': 'weapon_2h',
        };
        const slot = slotMap[itemClass.toLowerCase()] || null;
        if (slot) {
          // Try to find any base with this slot whose name appears in the item name
          foundBase = basesData.find((b: any) =>
            b.slot === slot && name.toLowerCase().includes(b.name.toLowerCase())
          );
        }
      }

// Parse modifier sections from the text. Supports two formats:
//   Wiki: "{ Prefix Modifier "Name" (Tier: N) — Tags }" + mod text on next line
//   In-game: "Prefix Modifier" header + tier (T1/T2) on its own line + mod text on next line
//          (in-game format has alternating T#/text lines for each affix)
      const affixes: any[] = [];
      let implicit = '';
      for (let i = 0; i < lines.length; i++) {
        const l = lines[i].trim();
        // Match wiki header OR in-game header
        const headerMatch = l.match(/^(\{\s*)?(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix|Implicit)\s+Modifier/i);
        if (!headerMatch) continue;
        const isCrafted = !!headerMatch[3];
        const isDesecrated = !!headerMatch[2];
        const modType = headerMatch[4].toLowerCase();
        // Get current section type — only emit affixes matching it
        let currentType = modType;

        // Walk subsequent lines, collecting mod blocks. Each block is either:
        //   Wiki: tier from header, then mod text, ends at separator/next header
        //   In-game: "T#" tier line, then mod text, then "T#" resets tier for next mod
        let j = i + 1;
        while (j < lines.length) {
          const nl = lines[j].trim();
          if (!nl) { j++; continue; }
          if (/^-{3,}$/.test(nl)) break;
          if (/^\{?\s*(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix|Implicit)\s+Modifier/i.test(nl)) break;

          // In-game format: "T1", "T2", etc. starts a new mod block
          const tierMatch = nl.match(/^T(\d+)$/);
          if (tierMatch) {
            const newTier = parseInt(tierMatch[1]);
            // Find the mod text that follows this tier line
            let modText = '';
            for (let k = j + 1; k < lines.length; k++) {
              const kk = lines[k].trim();
              if (!kk) continue;
              if (/^-{3,}$/.test(kk)) break;
              if (/^T\d+$/.test(kk)) break;
              if (/^\{?\s*(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix|Implicit)\s+Modifier/i.test(kk)) break;
              modText = kk;
              j = k; // skip past the mod text
              break;
            }
            if (modText && currentType !== 'implicit') {
              affixes.push({
                type: currentType,
                tier: newTier,
                crafted: isCrafted,
                desecrated: isDesecrated,
                name: modText,
              });
            }
            j++;
            continue;
          }

          // Wiki format: this is the mod text line (only when currentType is the
          // section header type, which is set on entry to this for iteration)
          if (currentType === 'implicit') {
            // Implicit has no tier — collect all lines until next header
            let text = nl;
            let k = j + 1;
            while (k < lines.length) {
              const kk = lines[k].trim();
              if (!kk) { k++; continue; }
              if (/^-{3,}$/.test(kk)) break;
              if (/^\{?\s*(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix|Implicit)\s+Modifier/i.test(kk)) break;
              if (/^T\d+$/.test(kk)) break;
              text += ' ' + kk;
              k++;
            }
            implicit = text.trim();
            j = k;
            continue;
          }

          // Wiki prefix/suffix: tier was on the header line (if any), text is here
          // Get tier from wiki header (for first mod of section)
          let tier = 1;
          const headerTier = l.match(/Tier\s*[\:\s]*(\d+)/i);
          if (headerTier) tier = parseInt(headerTier[1]);
          if (nl) {
            affixes.push({
              type: currentType,
              tier,
              crafted: isCrafted,
              desecrated: isDesecrated,
              name: nl,
            });
          }
          j++;
          break; // wiki format: one mod per section, move to next section
        }
        i = j - 1; // outer for loop increments i
      }

      // Build preview
      parsedPaste = {
        rarity, name,
        baseId: foundBase?.id || '',
        itemLevel,
        implicit,
        affixes,
      };

      pastePreview.classList.remove('hidden');
      const slotLabel: Record<string, string> = {
        amulet: 'Amulet', belt: 'Belt', body_armour: 'Body Armour',
        boots: 'Boots', charm: 'Charm', focus: 'Focus', gloves: 'Gloves',
        helmet: 'Helmet', jewel: 'Jewel', quiver: 'Quiver', ring: 'Ring',
        shield: 'Shield', weapon_1h: 'Weapon (1H)', weapon_2h: 'Weapon (2H)',
        waystone: 'Waystone', tablet: 'Tablet', relic: 'Relic',
      };
      const found = foundBase ? 'Matched' : 'Not matched';
      const sl = foundBase ? (slotLabel as any)[foundBase.slot] || foundBase.slot : 'unknown';
      pasteDetected.innerHTML = `
        <div class="flex items-center gap-2"><span class="text-dim">Name:</span> <span class="text-fg font-semibold">${escapeHtml(name)}</span></div>
        <div class="flex items-center gap-2"><span class="text-dim">Base:</span> <span class="${foundBase ? 'text-gold' : 'text-corrupted'}">${escapeHtml(foundBase?.name || 'Unknown')} (${sl})</span></div>
        <div class="flex items-center gap-2"><span class="text-dim">Rarity:</span> <span class="text-fg">${escapeHtml(rarity)}</span></div>
        <div class="flex items-center gap-2"><span class="text-dim">Item Level:</span> <span class="text-fg">${itemLevel}</span></div>
        <div class="flex items-center gap-2"><span class="text-dim">Mods:</span> <span class="text-fg">${affixes.length}${implicit ? ' + 1 implicit' : ''}</span></div>
        <div class="flex items-center gap-2"><span class="text-dim">Match:</span> <span class="${foundBase ? 'text-green-400' : 'text-corrupted'}">${found}</span></div>
      `;
      pasteImport.disabled = !foundBase;
    }

    function importPastedItem() {
      if (!parsedPaste || !parsedPaste.baseId) {
        flash('Could not import: base not found.', 'error');
        return;
      }
      const bid = parsedPaste.baseId;
      const base = basesData.find((b: any) => b.id === bid);
      if (!base) {
        flash('Could not find base in database.', 'error');
        return;
      }
      // Select the base in the picker
      basePicker.value = bid;
      selectBase(bid);
      // Set item level + apply parsed affixes
      ilvlInput.value = String(parsedPaste.itemLevel);
      if (currentItem) {
        currentItem.itemLevel = parsedPaste.itemLevel;
        currentItem.rarity = parsedPaste.rarity === 'magic' ? 'magic' : parsedPaste.rarity === 'normal' ? 'normal' : 'rare';
        currentItem.implicit = parsedPaste.implicit || '';
        const affixes: any[] = (parsedPaste.affixes || []).map((a: any) => ({
          modId: `imported_${a.type}_${a.name.slice(0, 20).replace(/\W+/g, '_').toLowerCase()}`,
          type: a.type, tier: a.tier || 1, name: a.name,
          tags: [], crafted: !!a.crafted, desecrated: !!a.desecrated,
        }));
        currentItem.affixes = affixes;
        // Bonus slots: desecrated prefix = +1 prefix slot, crafted suffix = +1 suffix slot
        currentItem.bonusPrefixSlots = affixes.filter((a: any) => (a.desecrated || a.crafted) && a.type === 'prefix').length;
        currentItem.bonusSuffixSlots = affixes.filter((a: any) => (a.desecrated || a.crafted) && a.type === 'suffix').length;
        history = [];
        costTracker.reset();
        activeOmens.clear();
        renderAll();
      }

      // Close modal
      closePasteModalFn();
      flash(`Imported ${parsedPaste.name} (${base.name}) — ${currentItem?.affixes?.length || 0} mods loaded`, 'ok');
      logActivity(`Imported ${parsedPaste.name} (${base.name}) — ${currentItem?.affixes?.length || 0} mods`, 'info');
    }

    // Wire paste buttons with null guards (DOM may be mocked in tests)
    if (pasteEmptyBtn || pasteBtn) {
      [pasteEmptyBtn, pasteBtn].forEach(btn => {
        if (btn) btn.addEventListener('click', openPasteModal);
      });
    }
    if (pasteCancel || closePasteModal) {
      [pasteCancel, closePasteModal].forEach(btn => {
        if (btn) btn.addEventListener('click', closePasteModalFn);
      });
    }
    if (pasteModal) {
      pasteModal.addEventListener('click', (e) => {
        if (e.target === pasteModal) closePasteModalFn();
      });
    }
    if (pasteTextarea) {
      // Debounce input — pasting fires many key events as the textarea fills.
      let pasteParseTimer: number | undefined;
      const scheduleParse = () => {
        if (pasteParseTimer) clearTimeout(pasteParseTimer);
        pasteParseTimer = window.setTimeout(handlePasteText, 80);
      };
      pasteTextarea.addEventListener('input', scheduleParse);
      pasteTextarea.addEventListener('paste', scheduleParse);
      pasteTextarea.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && (e.ctrlKey || e.metaKey) && pasteImport && !pasteImport.disabled) {
          e.preventDefault();
          importPastedItem();
        }
      });
    }
    if (pasteImport) {
      pasteImport.addEventListener('click', importPastedItem);
    }

    // Copy button: export current item as PoE2 clipboard text
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        if (!currentBase || !currentItem) {
          flash('No item to copy.', 'error');
          return;
        }
        const slotToClass: Record<string, string> = {
          amulet: 'Amulets', belt: 'Belts', body_armour: 'Body Armours',
          boots: 'Boots', charm: 'Charms', focus: 'Focuses',
          gloves: 'Gloves', helmet: 'Helmets', jewel: 'Jewels',
          quiver: 'Quivers', ring: 'Rings', shield: 'Shields',
          weapon_1h: 'One Handed Weapons', weapon_2h: 'Two Handed Weapons',
          waystone: 'Waystones', tablet: 'Tablets', relic: 'Relics',
          bracelet: 'Bracelets', flask: 'Flasks',
        };
        const itemClass = slotToClass[currentBase.slot] || currentBase.slot;
        const rarity = ({ normal: 'Normal', magic: 'Magic', rare: 'Rare', unique: 'Unique' } as any)[currentItem.rarity] || 'Rare';
        const lines: string[] = [
          `Item Class: ${itemClass}`,
          `Rarity: ${rarity}`,
          currentBase.name,
          '--------',
          `Item Level: ${currentItem.itemLevel}`,
          '--------',
        ];
        if (currentItem.implicit) {
          lines.push(`${currentItem.implicit} (implicit)`);
          lines.push('--------');
        }
        const prefixes = currentItem.affixes.filter((a: any) => a.type === 'prefix');
        const suffixes = currentItem.affixes.filter((a: any) => a.type === 'suffix');
        for (const a of prefixes) lines.push(a.name);
        if (prefixes.length > 0 && suffixes.length > 0) lines.push('--------');
        for (const a of suffixes) lines.push(a.name);
        if (currentItem.corrupted) {
          lines.push('--------');
          lines.push('Corrupted');
        }
        if (currentItem.fractured && currentItem.fractured.length > 0) {
          if (!currentItem.corrupted) lines.push('--------');
          lines.push('Fractured');
        }
        const text = lines.join('\n');

        try {
          await navigator.clipboard.writeText(text);
          flash('Item copied to clipboard!', 'ok');
          logActivity('Item copied to clipboard.', 'info');
        } catch {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          flash('Item copied to clipboard!', 'ok');
          logActivity('Item copied to clipboard (fallback).', 'info');
        }
      });
    }

    // Keyboard shortcuts
    const KEY_MAP: Record<string, string> = {
      t: 'orb_of_transmutation',
      a: 'orb_of_alchemy',
      r: 'regal_orb',
      e: 'exalted_orb',
      x: 'orb_of_annulment',
      c: 'chaos_orb',
      d: 'divine_orb',
      u: 'orb_of_augmentation',
      v: 'vaal_orb',
    };

    // Map currency id (or name) to the canonical operation id.
// First tries the id directly, then strips lesser/greater/perfect/corrupted prefix,
// then falls back to a name keyword lookup.
const CURRENCY_NAME_TO_OP: Array<[RegExp | string, string]> = [
  ['transmutation', 'orb_of_transmutation'],
  ['augmentation', 'orb_of_augmentation'],
  ['alchemy', 'orb_of_alchemy'],
  ['regal', 'regal_orb'],
  ['exalt', 'exalted_orb'],
  ['annul', 'orb_of_annulment'],
  ['chaos', 'chaos_orb'],
  ['divine', 'divine_orb'],
  ['chance', 'orb_of_chance'],
  ['vaal', 'vaal_orb'],
  ['desecrat', 'desecrate'],
  ['collarbone|jawbone|rib|cranium', 'desecrate'],
  ['liquid|potent|auspicious|concentrated|diluted|ancient|distilled', 'liquid_emotion'],
  ['catalyst', 'catalyst'],
  ['alloy', 'alloy'],
];
const OP_KEYBOARD_HINTS: Record<string, string> = {
  orb_of_transmutation: 'T', orb_of_alchemy: 'A', regal_orb: 'R',
  exalted_orb: 'E', orb_of_annulment: 'X', chaos_orb: 'C', divine_orb: 'D',
  orb_of_augmentation: 'U', vaal_orb: 'V',
};

function mapCurrencyToOp(id: string, name: string): string {
  if (OPERATIONS[id]) return id;
  const stripped = id.replace(/^(lesser_|greater_|perfect_|corrupted_)/, '');
  if (OPERATIONS[stripped]) return stripped;
  const n = name.toLowerCase();
  for (const [needle, opId] of CURRENCY_NAME_TO_OP) {
    if (typeof needle === 'string' ? n.includes(needle) : needle.test(n)) return opId;
  }
  return stripped || id;
}

function getOpKey(opId: string): string {
  return OP_KEYBOARD_HINTS[opId] || '';
}

    function usedCount(type: string) {
      return currentItem?.affixes.filter((a: any) => a.type === type).length || 0;
    }

    function renderItem() {
      if (!currentBase || !currentItem) return;
      const item = {
        rarity: currentItem.rarity,
        itemLevel: currentItem.itemLevel,
        affixes: currentItem.affixes,
        corrupted: currentItem.corrupted,
        implicit: currentBase.implicit || currentItem.implicit,
      };
      itemDisplay.innerHTML = renderItemCardHTML(currentBase, item);
    }

    function renderItemCardHTML(base: any, item: any): string {
      const prefixes = item.affixes.filter((a: any) => a.type === 'prefix');
      const suffixes = item.affixes.filter((a: any) => a.type === 'suffix');
      const slotTypeLabel = SLOT_LABELS[base.slot] || base.slot;

      const rowHTML = (a: any) => `
        <div class="item-row">
          <span class="mod-tier">T${a.tier}</span>
          <span class="mod-text" style="color: ${tagColor(a.tags || [])}">${escapeHtml(a.name)}</span>
        </div>
      `;

      const separatorHTML = (withIcon = true) => withIcon
        ? `<div class="separator"><span class="separator-line"></span><span class="separator-icon">+</span><span class="separator-line"></span></div>`
        : `<div class="separator plain"><span class="separator-line full"></span></div>`;

      return `
        <div class="item-tooltip">
          <div class="item-header">
            <div class="item-name" style="color: ${RARITY_COLORS[item.rarity] || RARITY_COLORS.normal}">${escapeHtml(base.name)}</div>
            <div class="item-type">${slotTypeLabel}</div>
          </div>
          ${item.implicit ? `
            <div class="item-section">
              <div class="item-row">
                <span class="mod-tier">-</span>
                <span class="mod-text implicit">${escapeHtml(item.implicit)}</span>
              </div>
            </div>
            ${separatorHTML(true)}
          ` : ''}
          ${prefixes.length > 0 ? `
            <div class="item-section">
              <div class="section-label">Prefix Modifier</div>
              ${prefixes.map(rowHTML).join('')}
            </div>
          ` : ''}
          ${suffixes.length > 0 && prefixes.length > 0 ? separatorHTML(true) : ''}
          ${suffixes.length > 0 ? `
            <div class="item-section">
              <div class="section-label">Suffix Modifier</div>
              ${suffixes.map(rowHTML).join('')}
            </div>
          ` : ''}
          ${prefixes.length === 0 && suffixes.length === 0 ? `<div class="item-empty">Empty item</div>` : ''}
          ${separatorHTML(false)}
          <div class="item-footer">
            <div class="item-rarity">${capitalize(item.rarity)} · Item Level: ${item.itemLevel}</div>
            ${item.corrupted ? `<div class="corrupted-indicator">Corrupted</div>` : ''}
          </div>
        </div>
      `;
    }

    function renderActiveOmens() {
      if (activeOmens.size === 0) {
        activeOmensStrip.classList.add('hidden');
        omensBtnLabel.textContent = '+ Add Omens';
        return;
      }
      activeOmensStrip.classList.remove('hidden');
      omensBtnLabel.textContent = `+ Omens (${activeOmens.size})`;
      const items = [...activeOmens].map((id) => {
        const o = omensData.find((x: OmenOpt) => x.id === id);
        if (!o) return '';
        return `<div class="flex items-center gap-1.5 pl-1 pr-2 py-1 border border-gold rounded bg-bg-elev text-xs">
          ${o.imageUrl ? `<img src="${o.imageUrl}" alt="${escapeHtml(o.name)}" class="w-5 h-5" />` : ''}
          <span class="text-gold-bright">${escapeHtml(o.name)}</span>
          <button class="omen-remove text-mute hover:text-corrupted leading-none text-base" data-id="${escapeHtml(o.id)}" aria-label="Remove ${escapeHtml(o.name)}">×</button>
        </div>`;
      }).join('');
      activeOmensChips.innerHTML = items;
      activeOmensChips.querySelectorAll<HTMLButtonElement>('.omen-remove').forEach((b) => {
        b.addEventListener('click', () => {
          activeOmens.delete(b.dataset.id!);
          renderActiveOmens();
          renderOmensModal();
        });
      });
    }

    function renderCurrencyStrip() {
      if (!currentBase) return;
      const availability = getCurrencyAvailability(currentItem, currentBase);
      const order = ['upgrade_rarity', 'augment', 'reroll', 'annul', 'divine', 'corrupt', 'desecrate', 'essence', 'catalyst', 'liquid_affector', 'breach', 'currency_other', 'special'];

      const grouped: Record<string, CurOpt[]> = {};
      for (const c of currencyData as CurOpt[]) {
        const opId = mapCurrencyToOp(c.id, c.name);
        const avail = availability[opId];
        if (!avail) continue;
        if (!grouped[c.category]) grouped[c.category] = [];
        grouped[c.category].push({ ...c, opId } as any);
      }

      let html = '';
      // Compute mod pool counts once per render — they don't change per button
      const prefixCount = currentItem && currentBase
        ? eligibleModCount(currentBase.slot, currentItem.itemLevel, 'prefix', modsData)
        : 0;
      const suffixCount = currentItem && currentBase
        ? eligibleModCount(currentBase.slot, currentItem.itemLevel, 'suffix', modsData)
        : 0;
      for (const cat of order) {
        const items = grouped[cat];
        if (!items || items.length === 0) continue;
        html += `<div class="col-span-full flex items-center gap-2 mt-1 first:mt-0">
          <span class="text-[10px] uppercase tracking-wider text-mute">${escapeHtml(categoryLabel(cat))}</span>
          <div class="flex-1 h-px bg-border"></div>
        </div>`;
        html += items.map((c: any) => {
          const a = availability[c.opId];
          const valid = a?.valid;
          const reason = a?.reason || '';
          const key = getOpKey(c.opId);
          const desc = (c.description || '').slice(0, 120);
          const guid = currentItem && currentBase
            ? guidanceFor(
                c.opId,
                currentItem.rarity,
                currentBase.slot,
                currentItem.itemLevel,
                prefixCount,
                suffixCount,
              )
            : { summary: desc || '', when: '', odds: undefined, costNote: undefined };
          const tipParts: string[] = [
            `<strong>${escapeHtml(c.name)}</strong>${key ? ` <span class="text-gold-bright">[${key}]</span>` : ''}`,
          ];
          if (guid.summary) tipParts.push(`<span class="text-dim">${escapeHtml(guid.summary)}</span>`);
          if (guid.when) tipParts.push(`<span class="text-gold text-[11px]">${escapeHtml(guid.when)}</span>`);
          if (guid.odds) tipParts.push(`<span class="text-blue-400 text-[11px]">${escapeHtml(guid.odds)}</span>`);
          if (guid.costNote) tipParts.push(`<span class="text-mute text-[11px]">${escapeHtml(guid.costNote)}</span>`);
          if (!valid && reason) tipParts.push(`<span class="text-corrupted mt-1 inline-block">⚠ ${escapeHtml(reason)}</span>`);
          const tooltipHtml = tipParts.join('<br/>');
          const cls = valid
            ? 'border-border-strong bg-bg hover:border-gold hover:bg-bg-hover cursor-pointer focus-visible:ring-2 focus-visible:ring-gold'
            : 'border-border bg-bg opacity-30 cursor-not-allowed';
          return `
            <button class="currency-btn relative flex flex-col items-center justify-center p-1 border ${cls} rounded transition-all aspect-square" data-op="${escapeHtml(c.opId)}" data-original-id="${escapeHtml(c.id)}" ${valid ? '' : 'disabled aria-disabled="true"'} aria-label="${escapeHtml(c.name)}${key ? ' [' + key + ']' : ''}${valid ? '' : ' (disabled)'}" data-tooltip-html="${escapeHtml(tooltipHtml)}">
              ${c.imageUrl ? `<img src="${c.imageUrl}" alt="" class="w-full h-full object-contain" loading="lazy" />` : `<div class="flex-1 flex items-center justify-center text-[10px] text-mute">${escapeHtml(c.name.slice(0,3))}</div>`}
              ${key ? `<span class="absolute top-0.5 right-1 text-[10px] text-gold-bright font-mono drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]">${key}</span>` : ''}
            </button>
          `;
        }).join('');
      }

      if (!html) {
        html = `<div class="col-span-full text-xs text-mute py-3 text-center">No currency can be applied to this item.</div>`;
      }
      currencyStrip.innerHTML = html;

      currencyStrip.querySelectorAll<HTMLButtonElement>('.currency-btn:not([disabled])').forEach((btn) => {
        const tt = btn.dataset.tooltipHtml || btn.getAttribute('aria-label') || '';
        attachTooltip(btn, tt);
        btn.addEventListener('click', () => {
          const opId = btn.dataset.op!;
          const originalId = btn.dataset.originalId || opId;
          const avail = getCurrencyAvailability(currentItem)[opId];
          if (avail && !avail.valid) { flash(avail.reason); return; }
          applyCraft(opId, originalId);
        });
      });
    }

    function categoryLabel(cat: string): string {
      return ({ upgrade_rarity: 'Upgrade', augment: 'Add Affix', reroll: 'Reroll', annul: 'Annul', divine: 'Divine', corrupt: 'Corrupt', desecrate: 'Desecrate', essence: 'Essences', breach: 'Breach', special: 'Special', catalyst: 'Catalysts', liquid_affector: 'Liquids', currency_other: 'Other' } as Record<string, string>)[cat] || cat;
    }

    function renderHistory() {
      const entries = currentItem?.history || [];
      historyCount.textContent = `(${entries.length})`;
      if (entries.length === 0) {
        historyList.innerHTML = '<li class="text-mute">No actions yet.</li>';
        return;
      }
      historyList.innerHTML = entries.slice().reverse().map((h: any) => `
        <li class="border-b border-border pb-1">
          <span class="text-gold">${escapeHtml(h.action)}</span>
          ${h.detail ? `<span class="text-dim"> - ${escapeHtml(h.detail)}</span>` : ''}
        </li>
      `).join('');
    }

    function renderTips() {
      if (!currentBase || !currentItem) return;
      const tips: string[] = [];
      const r = currentItem.rarity;
      const a = currentItem.affixes;
      const usedP = usedCount('prefix');
      const usedS = usedCount('suffix');
      const maxP = currentBase.affixSlots.prefix;
      const maxS = currentBase.affixSlots.suffix;

      if (r === 'normal') {
        tips.push(`<strong>Transmutation</strong> <span class="text-mute">[T]</span> rolls 1 random prefix.`);
        tips.push(`<strong>Alchemy</strong> <span class="text-mute">[A]</span> jumps to Rare with 4 affixes.`);
        tips.push(`<strong>Chance</strong> has ~1% to hit a Unique.`);
      } else if (r === 'magic') {
        if (a.length < 2) {
          const next = usedP > 0 ? 'suffix' : 'prefix';
          tips.push(`<strong>Augmentation</strong> <span class="text-mute">[U]</span> adds the missing ${next}.`);
        } else {
          tips.push(`<strong>Regal</strong> <span class="text-mute">[R]</span> upgrades to Rare with a 3rd affix. Add Sinistral/Dextral Coronation omen to force the type.`);
        }
      } else if (r === 'rare') {
        if (usedP >= maxP && usedS >= maxS) {
          tips.push(`<strong>Annul</strong> <span class="text-mute">[X]</span> removes a bad affix. Use Sinistral/Dextral omen to target type.`);
          tips.push(`<strong>Chaos</strong> <span class="text-mute">[C]</span> rerolls all affixes.`);
        } else {
          tips.push(`<strong>Exalted</strong> <span class="text-mute">[E]</span> adds a ${usedP < maxP && usedS < maxS ? '' : usedP < maxP ? 'prefix' : 'suffix'} affix.`);
          tips.push(`<strong>Chaos</strong> <span class="text-mute">[C]</span> rerolls all - useful if you want different affixes.`);
        }
        if (['amulet','ring','belt','weapon_1h','weapon_2h','quiver','jewel'].includes(currentItem.slot)) {
          tips.push(`<strong>Desecrate</strong> (bones) adds a faction-locked affix.`);
        }
      }

      if (currentItem.corrupted) {
        tips.push(`<span class="text-corrupted">Item is corrupted.</span> Most currency can't be applied.`);
      }

      tipsPanel.innerHTML = `
        <span class="text-xs uppercase tracking-wider text-mute font-semibold block mb-1">💡 What you can do</span>
        ${tips.length
          ? tips.map((t) => `<div class="leading-relaxed mb-1 last:mb-0">${t}</div>`).join('')
          : `<span class="text-dim">No specific tips for this state.</span>`}
      `;

      // Mod pool summary
      const ilvl = currentItem.itemLevel;
      const slot = currentBase.slot;
      const eligibleMods = (modsData as ModOpt[]).filter((m) => {
        if (m.level > ilvl) return false;
        if (m.domain.length === 0) return false;
        return m.domain.includes(slot as any);
      });
      const prefixes = eligibleMods.filter((m) => m.type === 'prefix');
      const suffixes = eligibleMods.filter((m) => m.type === 'suffix');
      const t1Examples = prefixes.filter((m) => m.tier === 1).slice(0, 2);

      modPoolSummary.innerHTML = `
        <div class="flex gap-3 mb-1.5">
          <div class="text-prefix"><span class="font-semibold">${prefixes.length}</span> prefixes</div>
          <div class="text-suffix"><span class="font-semibold">${suffixes.length}</span> suffixes</div>
        </div>
        ${t1Examples.length > 0
          ? `<div class="text-mute leading-relaxed">T1 examples: ${t1Examples.map((m) => escapeHtml(m.description.slice(0, 50))).join(' · ')}</div>`
          : `<div class="text-mute">No eligible T1 mods at ilvl ${ilvl}.</div>`}
      `;
    }

    function renderAll() {
      renderItem();
      renderActiveOmens();
      renderCurrencyStrip();
      renderHistory();
      renderTips();
      renderCostPanel();
    }

    function renderCostPanel() {
      if (!costPanel) return;
      if (!costTracker.ready) {
        costPanel.classList.add('hidden');
        return;
      }
      const total = costTracker.totalChaos();
      const steps = costTracker.getSteps();
      if (steps.length === 0) {
        costPanel.classList.add('hidden');
        return;
      }
      costPanel.classList.remove('hidden');

      if (costChaos) costChaos.textContent = Math.round(total).toLocaleString();
      if (costExalted) {
        const snap = costTracker.snapshot;
        const cpe = (snap?.chaosPerExalt && snap.chaosPerExalt > 0) ? snap.chaosPerExalt : 1 / 56;
        costExalted.textContent = (total / cpe).toFixed(1);
      }
      if (costDivine) {
        const snap = costTracker.snapshot;
        const cpd = (snap?.chaosPerDivine && snap.chaosPerDivine > 0) ? snap.chaosPerDivine : 7.5;
        costDivine.textContent = (total / cpd).toFixed(2);
      }

      if (costBreakdown) {
        const recent = steps.slice(-8);
        costBreakdown.innerHTML = recent.map((s) => {
          const costStr = s.chaosCost >= 1 ? `${s.chaosCost.toFixed(1)} chaos` : `${(s.chaosCost * 100).toFixed(0)}c alt`;
          return `<div>${s.currencyName} ×${s.count} - ${costStr}</div>`;
        }).join('');
      }

      if (costFallbackBadge) {
        const snap = costTracker.snapshot;
        if (snap && snap.fetchedAt && Object.keys(snap.prices).length <= 12) {
          costFallbackBadge.classList.remove('hidden');
        } else {
          costFallbackBadge.classList.add('hidden');
        }
      }
    }

    function applyCraft(opId: string, originalCurrencyId?: string) {
      if (!currentBase || !currentItem) { flash('Pick a base first.'); return; }
      const currencyId = originalCurrencyId || opId;
      const activeCurrency = (currencyData as CurOpt[]).find((c) => c.id === currencyId);
      const baseRecord: any = {
        id: currentBase.id, name: currentBase.name, slot: currentBase.slot, rarity: 'normal',
        level: currentBase.level, attributes: {}, baseStats: {}, imageUrl: currentBase.imageUrl,
        affixSlots: currentBase.affixSlots, family: currentBase.slot, variant: currentBase.variant,
        source: 'poe2db',
      };
      const ctx = {
        base: baseRecord,
        mods: modsData,
        currency: currencyData,
        omens: omensData,
        weights: weightsData,
        item: currentItem,
        activeOmens: [...activeOmens].map((id) => {
          const o = omensData.find((x: OmenOpt) => x.id === id);
          return { id, effect: parseOmenEffect(o) };
        }),
        minModLevel: typeof (activeCurrency as any)?.minModifierLevel === 'number' ? (activeCurrency as any).minModifierLevel : 0,
        activeCurrencyId: currencyId,
      };
      history.push(structuredClone(currentItem));
      const result = applyOperation(opId, ctx);
      currentItem = result.item;
      if (!result.ok) flash(result.message); else flash(result.message, 'ok');

      const opName = currencyData.find((c: CurOpt) => c.id === opId)?.name || opId;
      if (result.ok && result.item) {
        const a = result.item.affixes || [];
        const pCount = a.filter((m: any) => m.type === 'prefix').length;
        const sCount = a.filter((m: any) => m.type === 'suffix').length;
        const totalAffixes = pCount + sCount;
        const rarity = result.item.rarity || 'normal';
        const ctxPfx = totalAffixes > 0 ? ` → ${totalAffixes} affixes (${pCount}P / ${sCount}S) · ${rarity}` : '';
        logActivity(`${opName} on ${currentBase.name}${ctxPfx}.`, 'info');
      } else {
        logActivity(`${opName} on ${currentBase.name} - failed: ${result.message}`, 'error');
      }

      if (result.ok) {
        const displayName = activeCurrency?.name || opId.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
        costTracker.addStep(activeCurrency?.id || opId, displayName, 1);
      }

      activeOmens.clear();
      renderAll();
    }

    // Omen effect patterns, ordered from most-specific to most-generic. Each
// pattern maps to a kind+value used by the emulator.
const OMEN_EFFECT_RULES: Array<[RegExp, () => any]> = [
  [/only (have )?prefix|maximum number of prefix/, () => ({ kind: 'force_type', value: 'prefix' })],
  [/only (have )?suffix|maximum number of suffix/, () => ({ kind: 'force_type', value: 'suffix' })],
  [/adds 2 affixes|add two random modifiers|add two new random modifiers/, () => ({ kind: 'double_add' })],
  [/does not destroy|will not destroy/, () => ({ kind: 'no_destroy', for: 'orb_of_chance' })],
  [/remove two modifiers|removes 2 affixes/, () => ({ kind: 'remove_count', value: 2 })],
  [/removes 1 prefix|only prefix modifiers/, () => ({ kind: 'remove_type', value: 'prefix' })],
  [/removes 1 suffix|only suffix modifiers/, () => ({ kind: 'remove_type', value: 'suffix' })],
  [/lowest level/, () => ({ kind: 'remove_lowest_level' })],
  [/replaces? all (affixes|modifiers)|reroll (the options|desecrated modifiers)/, () => ({ kind: 'replace_all_desecrate' })],
  [/same type as an existing modifier/, () => ({ kind: 'force_homogenise' })],
  [/ulaman/, () => ({ kind: 'desecrate_faction', value: 'ulaman' })],
  [/amanamu/, () => ({ kind: 'desecrate_faction', value: 'amanamu' })],
  [/kurgal/, () => ({ kind: 'desecrate_faction', value: 'kurgal' })],
  [/desecrated affixes/, () => ({ kind: 'remove_only_desecrated' })],
  [/implicit/, () => ({ kind: 'divine_implicit_only' })],
  [/sanctif/, () => ({ kind: 'divine_upgrade' })],
  [/catalysing|catalyst/, () => ({ kind: 'exalted_consumes_catalyst' })],
  [/putrefaction/, () => ({ kind: 'desecrate_reroll' })],
  [/sinistral.*necromancy/, () => ({ kind: 'desecrate_minion', value: 'prefix' })],
  [/dextral.*necromancy/, () => ({ kind: 'desecrate_minion', value: 'suffix' })],
  [/crystallisation/, () => ({ kind: 'perfect_orb_implicit_upgrade' })],
  [/chaotic effectiveness/, () => ({ kind: 'chaos_effectiveness' })],
  [/chaotic monsters/, () => ({ kind: 'chaos_monsters' })],
  [/chaotic quantity/, () => ({ kind: 'chaos_quantity' })],
  [/chaotic rarity/, () => ({ kind: 'chaos_rarity' })],
  [/random unique|ancients/, () => ({ kind: 'specific_unique', for: 'orb_of_chance' })],
];
const OMEN_EFFECT_DEFAULT = { kind: 'force_type', value: 'prefix' };

function parseOmenEffect(o: OmenOpt | undefined): any {
  if (!o) return OMEN_EFFECT_DEFAULT;
  const e = (o.effect || '').toLowerCase();
  for (const [re, build] of OMEN_EFFECT_RULES) {
    if (re.test(e)) return build();
  }
  return OMEN_EFFECT_DEFAULT;
}

// Map omen name → category for the popover grid
const OMEN_CATEGORY_RULES: Array<[RegExp, string]> = [
  [/saga$/, 'Saga'],
  [/ancients|blackblooded|liege|sovereign/, 'Faction'],
  [/alchemy/, 'Alchemy'],
  [/coronation/, 'Coronation'],
  [/exaltation/, 'Exaltation'],
  [/annulment/, 'Annulment'],
  [/erasure/, 'Erasure'],
  [/crystallisation/, 'Crystallisation'],
  [/necromancy/, 'Necromancy'],
  [/chance/, 'Chance'],
  [/whittling/, 'Whittling'],
  [/abyssal/, 'Abyssal'],
  [/putrefaction/, 'Putrefaction'],
  [/light/, 'Light'],
  [/refreshment|resurgence|amelioration|bartering|answered|catalysing|chaotic|corruption/, 'Other'],
];

function categorizeOmen(name: string): string {
  const n = name.toLowerCase();
  for (const [re, cat] of OMEN_CATEGORY_RULES) {
    if (re.test(n)) return cat;
  }
  return 'Other';
}

    function renderOmensModal() {
      const grouped = new Map<string, OmenOpt[]>();
      for (const o of omensData as OmenOpt[]) {
        const cat = categorizeOmen(o.name);
        if (!grouped.has(cat)) grouped.set(cat, []);
        grouped.get(cat)!.push(o);
      }
      const orderKey = (k: string) => (k === 'Other' ? 'zzz' : k === 'Faction' ? 'zzy' : k === 'Saga' ? 'zzx' : k);
      const cats = [...grouped.keys()].sort((a, b) => orderKey(a).localeCompare(orderKey(b)));

      omenModalBody.innerHTML = cats.map((cat) => {
        const items = grouped.get(cat)!;
        return `
          <div class="omen-group mb-4" data-cat="${escapeHtml(cat.toLowerCase())}">
            <div class="text-[10px] uppercase tracking-wider text-mute mb-2 font-semibold">
              ${escapeHtml(cat)} <span class="text-fg-mute">(${items.length})</span>
            </div>
            <div class="grid grid-cols-6 sm:grid-cols-8 gap-1.5">
              ${items.map((o) => {
                const active = activeOmens.has(o.id);
                return `
                  <button
                    class="omen-btn relative aspect-square border ${active ? 'border-gold bg-bg-hover shadow-ornate' : 'border-border bg-bg hover:border-border-strong'} rounded transition-all hover:scale-105 focus-visible:ring-2 focus-visible:ring-gold"
                    data-omen="${escapeHtml(o.id)}"
                    aria-pressed="${active}"
                    aria-label="${escapeHtml(o.name)}">
                    ${o.imageUrl ? `<img src="${escapeHtml(o.imageUrl)}" alt="" class="w-full h-full object-contain p-0.5 ${active ? '' : 'opacity-60'}" loading="lazy" />` : `<span class="text-[9px] leading-tight p-1 block">${escapeHtml(o.name.slice(0, 8))}</span>`}
                    ${active ? '<span class="absolute -top-1 -right-1 w-3 h-3 bg-gold rounded-full border border-bg"></span>' : ''}
                  </button>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }).join('');

      omenModalBody.querySelectorAll<HTMLButtonElement>('.omen-btn').forEach((btn) => {
        const omenId = btn.dataset.omen!;
        const o = omensData.find((x: OmenOpt) => x.id === omenId);
        if (o) attachTooltip(btn, `<strong>${escapeHtml(o.name)}</strong><br/><span class="text-dim">${escapeHtml(o.effect)}</span>`);
        btn.addEventListener('click', () => {
          if (activeOmens.has(omenId)) activeOmens.delete(omenId);
          else activeOmens.add(omenId);
          renderOmensModal();
          omenModalCount.textContent = `${activeOmens.size} selected`;
        });
      });

      omenModalCount.textContent = `${activeOmens.size} selected`;
    }

    function selectBase(baseId: string) {
      const b = basesById?.get(baseId) ?? basesData.find((x: BaseOpt) => x.id === baseId);
      if (!b) return;
      currentBase = b;
      currentItem = emptyItem(makeBaseRecord(b, 'normal'), parseInt(ilvlInput.value || '80'));
      history = [];
      costTracker.reset();
      activeOmens.clear();
      emptyState.classList.add('hidden');
      mainUi.classList.remove('hidden');
      renderAll();
    }

    // Build O(1) lookup maps once after data is loaded
    const basesById = new Map<string, BaseOpt>(basesData.map((b: BaseOpt) => [b.id, b]));

    function finishLoad() {
      // Don't show empty state if a base was auto-selected via ?base= URL param
      if (currentBase) return;
      loadingState.classList.add('hidden');
      emptyState.classList.remove('hidden');
    }

    // Single source of truth for the base record shape consumed by emptyItem()
    function makeBaseRecord(b: BaseOpt, rarity: 'normal' | 'magic' | 'rare' | 'unique') {
      return {
        id: b.id, name: b.name, slot: b.slot, rarity, level: b.level,
        attributes: {}, baseStats: {}, imageUrl: b.imageUrl,
        affixSlots: b.affixSlots, family: b.slot, variant: b.variant,
        source: 'poe2db',
      } as any;
    }

    // Wire up UI
    basePicker.addEventListener('change', () => {
      if (basePicker.value) selectBase(basePicker.value);
    });
    ilvlInput.addEventListener('input', () => {
      if (currentItem) {
        currentItem.itemLevel = parseInt(ilvlInput.value || '80');
        // ilvl affects mod pool + currency availability — only re-render those.
        renderTips();
        renderCurrencyStrip();
      }
    });

    resetBtn.addEventListener('click', () => { if (currentBase) selectBase(currentBase.id); });
    seedRareBtn.addEventListener('click', () => {
      if (!currentBase) { flash('Pick a base first.'); return; }
      selectBase(currentBase.id);
      applyCraft('orb_of_alchemy');
      applyCraft('exalted_orb');
      applyCraft('exalted_orb');
    });
    undoBtn.addEventListener('click', () => {
      const prev = history.pop();
      if (prev) { currentItem = prev; costTracker.popStep(); renderAll(); flash('Undone.', 'ok'); }
    });
    clearOmensBtn.addEventListener('click', () => { activeOmens.clear(); renderAll(); });

    openOmensBtn.addEventListener('click', () => {
      renderOmensModal();
      omenModal.classList.remove('hidden');
    });
    closeOmenModal.addEventListener('click', () => omenModal.classList.add('hidden'));
    omenDone.addEventListener('click', () => omenModal.classList.add('hidden'));
    omenModal.addEventListener('click', (e) => { if (e.target === omenModal) omenModal.classList.add('hidden'); });
    omenClearAll.addEventListener('click', () => { activeOmens.clear(); renderOmensModal(); });
    omenSearch.addEventListener('input', () => {
      const q = omenSearch.value.toLowerCase().trim();
      omenModalBody.querySelectorAll<HTMLElement>('.omen-group').forEach((g) => {
        const cat = g.dataset.cat || '';
        const btns = g.querySelectorAll<HTMLButtonElement>('.omen-btn');
        let visible = 0;
        btns.forEach((b) => {
          const title = b.getAttribute('aria-label')?.toLowerCase() || '';
          const match = !q || cat.includes(q) || title.includes(q);
          b.classList.toggle('hidden', !match);
          if (match) visible++;
        });
        (g as HTMLElement).style.display = visible === 0 ? 'none' : '';
      });
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      if (!currentItem) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if (e.ctrlKey || e.metaKey || e.altKey) return;
      const key = e.key.toLowerCase();
      if (key === 'z' && !e.shiftKey) {
        e.preventDefault();
        undoBtn.click();
        return;
      }
      const opId = KEY_MAP[key];
      if (opId) {
        e.preventDefault();
        const avail = getCurrencyAvailability(currentItem)[opId];
        if (!avail?.valid) { flash(avail?.reason || 'Not available.'); return; }
        applyCraft(opId);
      }
    });

    // Initial URL param
    const params = new URLSearchParams(location.search);
    const initialBase = params.get('base');
    if (initialBase) {
      basePicker.value = initialBase;
      selectBase(initialBase);
    }

    // Seed activity log
    logActivity('Activity log started. Craft results will persist here until you click Clear.', 'info');

    // Initialize cost tracker — fetches live prices from poe2scout
    costTracker.init().then(() => {
      logActivity('Live pricing loaded from poe2scout.', 'info');
      if (currentBase) renderAll();
      else renderCostPanel();
});
  </script>
</Base>
