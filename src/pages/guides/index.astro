---
import Base from '~/layouts/Base.astro';
import { METHODS } from '~/lib/methods';
import { useT } from '~/lib/i18n';

const locale: 'en' | 'pt' = 'en';
const t = useT(locale);
---

<Base title={`${t('guides.title')} - Exile Crafter`}>
  <section class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-bg-card/80 to-bg p-6 md:p-8 mb-8 text-center">
    <div class="absolute -top-20 -left-20 w-48 h-48 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-12 -right-12 w-36 h-36 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="text-4xl mb-3">📖</div>
      <h1 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-gold-bright via-gold to-yellow-300 bg-clip-text text-transparent mb-2">
        {t('guides.title')}
      </h1>
      <p class="text-sm text-dim max-w-xl mx-auto">{t('guides.subtitle')}</p>
    </div>
  </section>

  <!-- Preview Card Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
    {METHODS.map((method) => (
      <a
        href={`#${method.id}`}
        class="group block rounded-xl border border-border bg-gradient-to-b from-bg-card/90 to-bg-card/50 p-5 transition-all duration-200 hover:border-gold/50 hover:shadow-lg hover:shadow-gold/5 hover:-translate-y-0.5"
      >
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="font-display font-bold text-base text-fg group-hover:text-gold transition-colors leading-tight">
            {method.name}
          </h3>
          <span class={`shrink-0 text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${
            method.difficulty === 'beginner' ? 'bg-green-900/40 text-green-400' :
            method.difficulty === 'intermediate' ? 'bg-yellow-900/40 text-yellow-400' :
            method.difficulty === 'advanced' ? 'bg-orange-900/40 text-orange-400' :
            'bg-red-900/40 text-red-400'
          }`}>
            {method.difficulty}
          </span>
        </div>
        <p class="text-xs text-dim leading-relaxed line-clamp-2 mb-3">
          {method.description}
        </p>
        <div class="flex flex-wrap gap-1.5">
          {method.bestFor.slice(0, 3).map((b) => (
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-bg border border-border text-dim">
              {b}
            </span>
          ))}
          {method.steps.length > 0 && (
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-bg border border-border text-dim">
              {method.steps.length} step{method.steps.length > 1 ? 's' : ''}
            </span>
          )}
        </div>
      </a>
    ))}
  </div>

  <div class="space-y-8">
    {METHODS.map((method) => (
      <article id={method.id} class="parchment p-6 scroll-mt-24">
        <div class="flex items-baseline gap-3 mb-3 flex-wrap">
          <h2 class="!m-0">{method.name}</h2>
          <span class="tag text-fg-dim capitalize">{t(`guides.difficulty.${method.difficulty}` as 'guides.difficulty.beginner')}</span>
        </div>
        <p class="text-dim">{method.description}</p>

        <div class="grid md:grid-cols-2 gap-6 mt-4">
          <div>
            <h4>{t('guides.steps')}</h4>
            <ol class="space-y-2 text-sm list-decimal list-inside text-fg">
              {method.steps.map((s) => <li class="leading-relaxed">{s}</li>)}
            </ol>
          </div>
          <div>
            <h4>{t('guides.bestFor')}</h4>
            <ul class="space-y-1 text-sm">
              {method.bestFor.map((b) => (
                <li class="text-fg">
                  <span class="text-gold mr-2">✦</span>{b}
                </li>
              ))}
            </ul>

            <div class="mt-6 flex gap-2">
              <a href="/simulator" class="btn">{t('guides.simulator')}</a>
              <a href="/calculator" class="btn">{t('guides.calculator')}</a>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</Base>
