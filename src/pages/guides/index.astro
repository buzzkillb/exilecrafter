---
import Base from '~/layouts/Base.astro';
import { METHODS } from '~/lib/methods';
import { useT } from '~/lib/i18n';

const locale = (Astro.locals.locale as 'en' | 'pt') ?? 'en';
const t = useT(locale);
---

<Base title={`${t('guides.title')} - CraftClass`}>
  <section class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-bg-card/80 to-bg p-6 md:p-8 mb-8 text-center">
    <div class="absolute -top-20 -left-20 w-48 h-48 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-12 -right-12 w-36 h-36 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="text-4xl mb-3">📖</div>
      <h1 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-gold-bright via-gold to-yellow-300 bg-clip-text text-transparent mb-2">
        {t('guides.title')}
      </h1>
      <p class="text-sm text-dim max-w-xl mx-auto">{t('guides.subtitle')}</p>
    </div>
  </section>

  <div class="space-y-8">
    {METHODS.map((method) => (
      <article id={method.id} class="parchment p-6 scroll-mt-24">
        <div class="flex items-baseline gap-3 mb-3 flex-wrap">
          <h2 class="!m-0">{method.name}</h2>
          <span class="tag text-fg-dim capitalize">{t(`guides.difficulty.${method.difficulty}` as 'guides.difficulty.beginner')}</span>
        </div>
        <p class="text-dim">{method.description}</p>

        <div class="grid md:grid-cols-2 gap-6 mt-4">
          <div>
            <h4>{t('guides.steps')}</h4>
            <ol class="space-y-2 text-sm list-decimal list-inside text-fg">
              {method.steps.map((s) => <li class="leading-relaxed">{s}</li>)}
            </ol>
          </div>
          <div>
            <h4>{t('guides.bestFor')}</h4>
            <ul class="space-y-1 text-sm">
              {method.bestFor.map((b) => (
                <li class="text-fg">
                  <span class="text-gold mr-2">✦</span>{b}
                </li>
              ))}
            </ul>

            <div class="mt-6 flex gap-2">
              <a href="/simulator" class="btn">{t('guides.simulator')}</a>
              <a href="/calculator" class="btn">{t('guides.calculator')}</a>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</Base>
