---
import Base from '~/layouts/Base.astro';
import BaseCard from '~/components/BaseCard.astro';
import { searchBases, SLOTS } from '~/lib/data';
import { useT } from '~/lib/i18n';

const locale = (Astro.locals.locale as 'en' | 'pt') ?? 'en';
const t = useT(locale);

const url = new URL(Astro.request.url);
const slot = url.searchParams.get('slot') || undefined;
const q = url.searchParams.get('q') || '';
const results = searchBases(q, slot).slice(0, 200);
---

<Base title={`${t('bases.title')} | Exile Crafter`}>
  <section class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-bg-card/80 to-bg p-6 md:p-8 mb-8 text-center">
    <div class="absolute -top-20 -left-20 w-48 h-48 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-12 -right-12 w-36 h-36 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="text-4xl mb-3">📦</div>
      <h1 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-gold-bright via-gold to-yellow-300 bg-clip-text text-transparent mb-2">
        {t('bases.title')}
      </h1>
      <p class="text-sm text-dim max-w-xl mx-auto">{t('bases.subtitle')}</p>
    </div>
  </section>

  <form method="get" class="parchment p-4 mb-6 flex gap-3 items-end flex-wrap">
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs text-mute mb-1">{t('bases.search.label')}</label>
      <input
        type="text"
        name="q"
        value={q}
        placeholder={t('bases.search.placeholder')}
        class="w-full bg-bg border border-border-strong rounded px-3 py-2 text-sm focus:outline-none focus:border-gold"
      />
    </div>
    <div>
      <label class="block text-xs text-mute mb-1">{t('bases.slot.label')}</label>
      <select
        name="slot"
        class="bg-bg border border-border-strong rounded px-3 py-2 text-sm focus:outline-none focus:border-gold"
      >
        <option value="">{t('bases.slot.all')}</option>
        {SLOTS.map((s) => (
          <option value={s} selected={slot === s}>{t(`slots.${s}` as 'slots.helmet')}</option>
        ))}
      </select>
    </div>
    <button type="submit" class="btn btn-gold">{t('bases.filter')}</button>
    {(q || slot) && <a href="/bases" class="btn">{t('bases.clear')}</a>}
  </form>

  <div class="text-sm text-mute mb-3">{t('bases.results', { count: results.length })}</div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
    {results.map((base) => (
      <BaseCard base={base} href={`/bases/${base.id}`} />
    ))}
  </div>
</Base>
