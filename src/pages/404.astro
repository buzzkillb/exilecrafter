---
import Base from '~/layouts/Base.astro';
---

<Base title="Not Found | CraftClass">
  <section class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-bg-card/80 to-bg p-8 md:p-12 mb-8 text-center max-w-xl mx-auto mt-16">
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-16 -right-16 w-48 h-48 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="text-6xl mb-4">🔮</div>
      <h1 class="text-6xl font-display font-bold bg-gradient-to-r from-gold-bright via-gold to-yellow-300 bg-clip-text text-transparent mb-3">
        404
      </h1>
      <p class="text-dim mb-2">This waystone leads nowhere.</p>
      <p class="text-xs text-mute mb-6">The item you're looking for was lost to the void.</p>
      <a href="/" class="btn btn-gold px-6 py-3">Back to the Hideout</a>
    </div>
  </section>
</Base>
