---
import Base from '~/layouts/Base.astro';
import { currency } from '~/lib/data';
import { useT } from '~/lib/i18n';

const locale = (Astro.locals.locale as 'en' | 'pt') ?? 'en';
const t = useT(locale);

const groups: Record<string, typeof currency> = {};
for (const c of currency) {
  const key = c.category;
  if (!groups[key]) groups[key] = [];
  groups[key].push(c);
}

const groupOrder = ['upgrade_rarity', 'augment', 'reroll', 'annul', 'divine', 'corrupt', 'essence', 'catalyst', 'liquid_affector', 'desecrate', 'omen', 'refinement', 'currency_other', 'special'];
---

<Base title={`${t('currency.title')} | CraftClass`}>
  <section class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-bg-card/80 to-bg p-6 md:p-8 mb-8 text-center">
    <div class="absolute -top-20 -left-20 w-48 h-48 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-12 -right-12 w-36 h-36 bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative">
      <div class="text-4xl mb-3">💰</div>
      <h1 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-gold-bright via-gold to-yellow-300 bg-clip-text text-transparent mb-2">
        {t('currency.title')}
      </h1>
      <p class="text-sm text-dim max-w-xl mx-auto">{t('currency.subtitle')}</p>
    </div>
  </section>

  {groupOrder.map((g) => {
    const items = groups[g];
    if (!items || items.length === 0) return null;
    return (
      <section class="mb-8">
        <h2>{t(`currency.category.${g}` as 'currency.category.upgrade_rarity')}</h2>
        <div class="divider-ornate"></div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
          {items.map((c) => (
            <div class="parchment p-4 flex gap-3">
              <div class="icon-frame">
                {c.imageUrl && <img src={c.imageUrl} alt={c.name} />}
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-display text-gold-bright">{c.name}</div>
                <div class="text-xs text-mute capitalize mb-1">
                  {c.tier !== 'normal' && <span>{c.tier} · </span>}
                  {t('currency.stack', { size: c.stackSize || 20 })}
                </div>
                <div class="text-xs text-dim leading-relaxed">{c.description || c.mechanics}</div>
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Base>
