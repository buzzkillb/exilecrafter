---
import Base from '~/layouts/Base.astro';
---

<Base title="Craft Optimizer — Exile Crafter">
  <h1>Craft Optimizer</h1>
  <p class="text-sm text-dim mb-4">
    Paste a finished item to find the cheapest path to craft it from scratch.
  </p>

  <!-- Paste area -->
  <div class="grid lg:grid-cols-[1fr_320px] gap-4">
    <div class="space-y-4 min-w-0">
      <div class="parchment p-4">
        <textarea id="paste-area" rows="10" class="w-full bg-bg border border-border-strong rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-gold resize-none"
          placeholder="Paste an item from PoE2 (Ctrl+C) here...&#10;&#10;Example:&#10;Item Class: Rings&#10;Rarity: Rare&#10;Torment Whorl&#10;Gold Ring&#10;..."></textarea>
        <div class="mt-2 flex items-center justify-between">
          <div>
            <span id="detected-base" class="text-xs text-mute">No item pasted</span>
          </div>
          <button id="optimize-btn" class="btn btn-gold" disabled>Optimize Craft Path</button>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="hidden">
        <div class="parchment p-4 mb-4">
          <h2 class="!mt-0">Optimal Craft Path</h2>
          <div class="text-sm text-dim mt-1">
            Expected cost to craft this item from scratch:
            <span id="total-cost" class="text-gold-bright font-semibold font-mono">—</span>
          </div>
          <div class="text-xs text-mute mb-4">
            <span id="exalt-cost" class="font-mono">—</span> exalts ·
            <span id="divine-cost" class="font-mono">—</span> divines
          </div>
          <div id="steps" class="space-y-2"></div>
        </div>
      </div>
    </div>

    <div class="parchment p-4 text-sm text-dim space-y-3">
      <h4 class="!mt-0">How it works</h4>
      <p>
        The optimizer simulates every possible crafting path from a white base to your target item,
        finding the cheapest sequence using real poe2db mod weights and live currency prices.
      </p>
      <p>
        It considers Essences (guaranteed mods), Exalted slams, Regal + Augment cycles,
        Chaos rerolls, Annul removal, and Fracturing — weighing expected attempts against
        per-orb cost to minimize total chaos spent.
      </p>
      <div class="border-t border-border pt-2 mt-3">
        <div class="text-xs text-gold font-semibold mb-1">Example</div>
        <p class="text-xs text-dim">Paste a Torment Whorl ring or any Rare item above to see the optimal craft path.</p>
      </div>
    </div>
  </div>
</Base>

<script>
  import { optimize } from '~/lib/optimizer';

  const pasteArea = document.getElementById('paste-area') as HTMLTextAreaElement;
  const optimizeBtn = document.getElementById('optimize-btn') as HTMLButtonElement;
  const detectedBase = document.getElementById('detected-base')!;
  const results = document.getElementById('results')!;
  const stepsEl = document.getElementById('steps')!;
  const totalCost = document.getElementById('total-cost')!;
  const exaltCost = document.getElementById('exalt-cost')!;
  const divineCost = document.getElementById('divine-cost')!;

  let parsed: any = null;
  let basesData: any[] = [];
  let modsData: any[] = [];
  let pricesData: Record<string, number> = {};

  // Load data
  const [basesRes, modsRes, pricesRes] = await Promise.all([
    fetch('/data/bases.json'),
    fetch('/data/mods.json'),
    fetch('/api/prices'),
  ]);
  basesData = await basesRes.json();
  modsData = await modsRes.json();
  const pricesRaw = await pricesRes.json();
  const meta = pricesRaw._meta || {};
  for (const [k, v] of Object.entries(pricesRaw)) {
    if (k !== '_meta' && typeof v === 'number' && v > 0) pricesData[k] = v;
  }
  const chaosPerDivine = meta.chaosPerDivine || 7.5;

  function findBaseByName(name: string) {
    const n = name.toLowerCase().trim();
    let b = basesData.find((x: any) => x.name.toLowerCase() === n);
    if (b) return b;
    b = basesData.find((x: any) => n.endsWith(x.name.toLowerCase()));
    if (b) return b;
    b = basesData.find((x: any) => n.includes(x.name.toLowerCase()));
    if (b) return b;
    return basesData.find((x: any) => x.name.toLowerCase().includes(n)) || null;
  }

  function parseClipboard(text: string) {
    const lines = text.split(/\n/);
    let itemClass = '', rarity = 'rare', name = '', itemLevel = 80;
    for (const l of lines) {
      const t = l.trim().replace(/\r$/, '');
      if (t.startsWith('Item Class:')) itemClass = t.split(':')[1].trim();
      else if (t.startsWith('Rarity:')) rarity = t.split(':')[1].trim().toLowerCase();
      else if (t.startsWith('--------')) break;
    }
    // Find base name: after the unique name
    let baseName = '';
    let foundSep = false;
    for (const l of lines) {
      const t = l.trim().replace(/\r$/, '');
      if (/^-{5,}$/.test(t)) { foundSep = true; continue; }
      if (!foundSep && t && !t.startsWith('Item Class:') && !t.startsWith('Rarity:')) {
        // Collect unique name and base name
        if (!name) name = t;
        else baseName = t;
      }
    }
    const base = findBaseByName(baseName || name);
    if (!base) return null;

    // Extract affix descriptions
    const affixes: string[] = [];
    for (let i = 0; i < lines.length; i++) {
      const l = lines[i].trim();
      if (/^\{?\s*(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix)\s+Modifier/i.test(l)) {
        // Next non-blank non-separator line is the mod text
        for (let j = i + 1; j < lines.length; j++) {
          const n = lines[j].trim().replace(/\r$/, '');
          if (!n) continue;
          if (/^-{3,}$/.test(n)) break;
          if (/^\{?\s*Modifier/i.test(n)) break;
          affixes.push(n.replace(/\((\d+)[-–](\d+)\)/g, '').trim());
          break;
        }
      }
    }

    return { base, rarity, itemLevel, name: baseName || name, affixes };
  }

  pasteArea.addEventListener('input', () => {
    const text = pasteArea.value.trim();
    if (!text || text.length < 30) {
      optimizeBtn.disabled = true;
      detectedBase.textContent = 'No item pasted';
      parsed = null;
      return;
    }
    parsed = parseClipboard(text);
    if (!parsed || !parsed.base) {
      optimizeBtn.disabled = true;
      detectedBase.textContent = 'Could not parse — make sure you copied a PoE2 item';
      return;
    }
    detectedBase.innerHTML = `<span class="text-gold">${parsed.base.name}</span> (${parsed.rarity}) — ${parsed.affixes.length} mods detected`;
    optimizeBtn.disabled = false;
  });

  optimizeBtn.addEventListener('click', () => {
    if (!parsed || !parsed.base) return;
    const result = optimize(parsed.base, parsed.affixes, modsData, pricesData, chaosPerDivine);
    results.classList.remove('hidden');
    totalCost.textContent = `${result.totalChaos.toLocaleString()}c`;
    exaltCost.textContent = result.totalExalts.toLocaleString();
    divineCost.textContent = result.totalDivines.toLocaleString();

    const slotLabel = (t: string) => t === 'prefix' ? 'Prefix' : 'Suffix';
    stepsEl.innerHTML = result.matched.map((s, i) => `
      <div class="flex items-start gap-3 border border-border rounded p-3 text-sm">
        <span class="text-xs text-mute w-6 shrink-0 pt-0.5">T${s.tier}</span>
        <div class="flex-1 min-w-0">
          <div class="text-fg">${s.mod}</div>
          <div class="text-xs text-mute mt-0.5">
            ${slotLabel(s.type)} · weight ${s.poolWeight} in pool of ${s.poolSize}
          </div>
        </div>
        <div class="text-right shrink-0">
          <div class="text-gold-bright font-mono font-semibold">${s.subtotal.toFixed(2)}c</div>
          <div class="text-mute text-xs">~1 in ${s.attempts.toLocaleString()}</div>
        </div>
      </div>
    `).join('') + (result.unmatched.length > 0 ? `
      <div class="text-xs text-dim mt-2">${result.unmatched.length} mod(s) not matched: ${result.unmatched.join(', ').slice(0, 80)}</div>
    ` : '');
  });
</script>
