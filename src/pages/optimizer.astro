---
import Base from '~/layouts/Base.astro';
---

<Base
  title="Craft Optimizer | Exile Crafter"
  description="Analyze a pasted Path of Exile 2 item and estimate crafting costs for its affixes with Exalted Orbs and alternative methods."
  robots="noindex,follow"
>
  <h1>Craft Optimizer</h1>
  <p class="text-sm text-dim mb-4">
    Paste a finished item to see expected costs for each affix using real poe2db weights and live prices.
  </p>

  <div class="grid lg:grid-cols-[1fr_280px] gap-4">
    <div class="space-y-4 min-w-0">
      <div class="parchment p-4">
        <textarea id="paste-area" rows="10" class="w-full bg-bg border border-border-strong rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-gold resize-none"
          placeholder="Paste an item from PoE2 (Ctrl+C) here..."></textarea>
        <div class="mt-2 flex items-center justify-between">
          <span id="detected-base" class="text-xs text-mute">No item pasted</span>
          <button id="optimize-btn" class="btn btn-gold" disabled>Analyze</button>
        </div>
      </div>

      <div id="results" class="hidden space-y-4">
        <div class="parchment p-4">
          <h2 class="!mt-0">Expected cost per affix (Exalted spam)</h2>
          <div class="text-sm mt-1">Total: <span id="total-cost" class="text-gold-bright font-semibold font-mono">—</span></div>
          <div id="steps" class="space-y-2 mt-3"></div>
        </div>
      </div>
    </div>

    <div class="parchment p-4 text-sm text-dim space-y-3">
      <h2 class="!mt-0">How it works</h2>
      <p>For each affix, it matches the pasted text to the correct mod using numeric range matching, then computes the expected number of Exalted slams using the real poe2db DropChance weight.</p>
      <p>If a matching essence exists at a lower cost, it's shown as an alternative.</p>
    </div>
  </div>
</Base>

<script>
  import { optimize } from '~/lib/optimizer';
  import { escapeHtml } from '~/lib/safe-html.js';

  const pasteArea = document.getElementById('paste-area') as HTMLTextAreaElement;
  const optimizeBtn = document.getElementById('optimize-btn') as HTMLButtonElement;
  const detectedBase = document.getElementById('detected-base')!;
  const results = document.getElementById('results')!;
  const stepsEl = document.getElementById('steps')!;
  const totalCost = document.getElementById('total-cost')!;

  let basesData: any[] = [];
  let modsData: any[] = [];
  let allCurrency: any[] = [];
  let pricesData: Record<string, number> = {};
  let parsed: any = null;

  const [basesRes, modsRes, currencyRes, pricesRes] = await Promise.all([
    fetch('/data/bases.json'), fetch('/data/mods.json'),
    fetch('/data/currency.json'), fetch('/api/prices'),
  ]);
  basesData = await basesRes.json();
  modsData = await modsRes.json();
  allCurrency = await currencyRes.json();
  const raw = await pricesRes.json();
  for (const [k, v] of Object.entries(raw)) { if (k !== '_meta' && typeof v === 'number' && v > 0) pricesData[k] = v; }

  function findBase(name: string) {
    const n = name.toLowerCase().trim();
    return basesData.find((x: any) => x.name.toLowerCase() === n)
      || basesData.find((x: any) => x.name.toLowerCase().includes(n))
      || null;
  }

  function parseClipboard(text: string) {
    const lines = text.split('\n');
    let name = '', baseName = '', foundSep = false;
    for (const l of lines) {
      const t = l.trim().replace(/\r$/, '');
      if (/^-{5,}$/.test(t)) { foundSep = true; continue; }
      if (!foundSep && t && !t.startsWith('Item Class:') && !t.startsWith('Rarity:')) {
        if (!name) name = t; else baseName = t;
      }
    }
    const base = findBase(baseName || name);
    if (!base) return null;

    const affixes: string[] = [];
    for (let i = 0; i < lines.length; i++) {
      const l = lines[i].trim();
      if (/^\{?\s*(Crafted\s+)?(Desecrated\s+)?(Prefix|Suffix)\s+Modifier/i.test(l)) {
        for (let j = i + 1; j < lines.length; j++) {
          const n = lines[j].trim().replace(/\r$/, '');
          if (!n) continue; if (/^-{3,}$/.test(n)) break; if (/^\{?\s*Modifier/i.test(n)) break;
          affixes.push(n.replace(/\(\d+[-–]\d+\)/g, m => m).trim());
          break;
        }
      }
    }
    return { base, name: baseName || name, affixes };
  }

  pasteArea.addEventListener('input', () => {
    const text = pasteArea.value.trim();
    if (text.length < 30) { optimizeBtn.disabled = true; detectedBase.textContent = 'No item pasted'; parsed = null; return; }
    parsed = parseClipboard(text);
    if (!parsed?.base) { optimizeBtn.disabled = true; detectedBase.textContent = 'Could not detect base'; return; }
    detectedBase.textContent = `${parsed.base.name} — ${parsed.affixes.length} affixes`;
    optimizeBtn.disabled = false;
  });

  optimizeBtn.addEventListener('click', () => {
    if (!parsed?.base) return;
    const result = optimize(parsed.base, parsed.affixes, modsData, allCurrency, pricesData);
    results.classList.remove('hidden');
    totalCost.textContent = result.totalChaos.toLocaleString() + 'c';
    stepsEl.innerHTML = result.affixes.map((a) => `
      <div class="border border-border rounded p-3 text-sm">
        <div class="flex items-start gap-2">
          <span class="text-xs font-mono text-mute shrink-0 pt-0.5">T${a.tier}</span>
          <div class="flex-1 min-w-0">
            <div class="text-fg truncate" title="${escapeHtml(a.matchedMod)}">${escapeHtml(a.matchedMod)}</div>
            <div class="text-xs text-mute mt-0.5">${escapeHtml(a.type)} \u00b7 weight ${a.weight} in pool of ${a.poolSize}</div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-gold-bright font-mono font-semibold">${a.strategies[0]?.expectedCost.toFixed(2) || '?'}c</div>
            <div class="text-mute text-xs">~1 in ${a.strategies[0]?.attempts.toLocaleString() || '?'}</div>
          </div>
        </div>
        ${a.strategies.length > 1 ? '<div class="mt-2 pt-2 border-t border-border space-y-1">' + a.strategies.slice(1).map(s =>
          `<div class="flex items-center justify-between text-xs text-dim">
            <span>${escapeHtml(s.method)}</span>
            <span class="font-mono${s.expectedCost < a.strategies[0].expectedCost ? ' text-gold-bright' : ''}">${s.expectedCost.toFixed(2)}c</span>
          </div>`
        ).join('') + '</div>' : ''}
      </div>
    `).join('') + (result.unmatched.length > 0 ? `<div class="text-xs text-dim">${result.unmatched.length} affixes not matched</div>` : '');
  });
</script>
